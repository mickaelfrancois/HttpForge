@page "/teams/{TeamId:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject TeamService TeamService
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Team — HttpForge</PageTitle>

@if (_team is null)
{
    <div class="team-page"><p>Team not found or access denied.</p></div>
}
else
{
    <div class="team-page">
        <h2 class="team-page-title">@_team.Name</h2>

        @* ── Members ── *@
        <section class="team-section">
            <h3 class="team-section-title">Members</h3>
            @foreach (var m in _team.Members)
            {
                <div class="team-member-row">
                    <span class="team-member-email">@(_emailMap.TryGetValue(m.UserId, out var e) ? e : m.UserId)</span>
                    <span class="role-badge role-@m.Role.ToString().ToLower()">@RoleLabel(m.Role)</span>
                    @if (_isAdmin && m.UserId != _currentUserId)
                    {
                        <button class="btn-sm btn-danger" @onclick="() => RemoveMemberAsync(m)">Remove</button>
                    }
                </div>
            }
            @if (_team.Members.Count == 0)
            {
                <p class="empty-hint">No members yet.</p>
            }
        </section>

        @* ── Invite (admin only) ── *@
        @if (_isAdmin)
        {
            <section class="team-section">
                <h3 class="team-section-title">Invite a member</h3>
                <div class="invite-form">
                    <input class="team-input" type="email" placeholder="Email address"
                           @bind="_inviteEmail" @bind:event="oninput" />
                    <select class="team-select" @bind="_inviteRole">
                        <option value="TeamAdmin">Team Admin</option>
                        <option value="Contributor">Contributor</option>
                        <option value="Guest">Guest</option>
                    </select>
                    <button class="btn-primary-sm" @onclick="InviteAsync"
                            disabled="@string.IsNullOrWhiteSpace(_inviteEmail)">
                        Send invitation
                    </button>
                </div>

                @if (_inviteToken is not null)
                {
                    <div class="invite-result">
                        <span class="invite-result-label">Invitation link:</span>
                        <code class="invite-result-link">@_inviteBaseUrl/invite/@_inviteToken</code>
                        <button class="btn-copy" @onclick="CopyInviteLink" title="Copy link">
                            @(_copied ? "✓ Copied" : "Copy")
                        </button>
                    </div>
                }
            </section>

            @* ── Pending invitations ── *@
            @if (_pendingInvitations.Count > 0)
            {
                <section class="team-section">
                    <h3 class="team-section-title">Pending invitations</h3>
                    @foreach (var inv in _pendingInvitations)
                    {
                        <div class="team-member-row">
                            <span class="team-member-email">@inv.Email</span>
                            <span class="role-badge role-@inv.Role.ToLower()">@inv.Role</span>
                            <span class="team-meta">expires @inv.ExpiresAt.ToLocalTime().ToString("g")</span>
                        </div>
                    }
                </section>
            }

            @* ── Orphaned collections ── *@
            @if (_orphanedCollections.Count > 0)
            {
                <section class="team-section">
                    <h3 class="team-section-title">Unassigned collections</h3>
                    <p class="team-hint">These collections are not assigned to any team.</p>
                    @foreach (var col in _orphanedCollections)
                    {
                        <div class="team-member-row">
                            <span class="team-member-email">@col.Name</span>
                            <button class="btn-primary-sm" @onclick="() => AssignCollectionAsync(col.Id)">
                                Assign to this team
                            </button>
                        </div>
                    }
                </section>
            }
        }

        @* ── Collections ── *@
        <section class="team-section">
            <h3 class="team-section-title">Collections</h3>
            @foreach (var col in _teamCollections)
            {
                <div class="team-member-row">
                    <span class="team-member-email">@col.Name</span>
                </div>
            }
            @if (_teamCollections.Count == 0)
            {
                <p class="empty-hint">No collections assigned to this team yet.</p>
            }
        </section>
    </div>
}

@code {
    [Parameter] public int TeamId { get; set; }

    private Team? _team;
    private List<InvitationToken> _pendingInvitations = [];
    private List<Collection> _orphanedCollections = [];
    private List<Collection> _teamCollections = [];
    private Dictionary<string, string> _emailMap = [];
    private bool _isAdmin;
    private string? _currentUserId;
    private string _inviteEmail = string.Empty;
    private string _inviteRole = "Contributor";
    private string? _inviteToken;
    private bool _copied;
    private string _inviteBaseUrl = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        var isSuperAdmin = authState.User.IsInRole("SuperAdmin");

        _team = await TeamService.GetTeamAsync(TeamId);
        if (_team is null) return;

        _isAdmin = isSuperAdmin
            || _team.Members.Any(m => m.UserId == _currentUserId && m.Role == TeamRole.TeamAdmin);

        if (!_isAdmin && !_team.Members.Any(m => m.UserId == _currentUserId))
        {
            Navigation.NavigateTo("/", forceLoad: true);
            return;
        }

        _inviteBaseUrl = Navigation.BaseUri.TrimEnd('/');
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _team = await TeamService.GetTeamAsync(TeamId);
        _teamCollections = await TeamService.GetTeamCollectionsAsync(TeamId);

        if (_isAdmin)
        {
            _pendingInvitations = await TeamService.GetPendingInvitationsAsync(TeamId);
            _orphanedCollections = await TeamService.GetOrphanedCollectionsAsync();
        }

        await LoadEmailsAsync();
    }

    private async Task LoadEmailsAsync()
    {
        if (_team is null) return;
        var ids = _team.Members.Select(m => m.UserId).ToList();
        using var db = await DbFactory.CreateDbContextAsync();
        _emailMap = await db.Users
            .Where(u => ids.Contains(u.Id))
            .AsNoTracking()
            .ToDictionaryAsync(u => u.Id, u => u.Email ?? u.UserName ?? u.Id);
    }

    private async Task InviteAsync()
    {
        if (string.IsNullOrWhiteSpace(_inviteEmail)) return;
        if (!Enum.TryParse<TeamRole>(_inviteRole, out var role)) return;
        var inv = await TeamService.InviteMemberAsync(TeamId, _inviteEmail, role);
        _inviteToken = inv.Token;
        _copied = false;
        _inviteEmail = string.Empty;
        await ReloadAsync();
    }

    private async Task CopyInviteLink()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", $"{_inviteBaseUrl}/invite/{_inviteToken}");
        _copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _copied = false;
        StateHasChanged();
    }

    private async Task RemoveMemberAsync(TeamMember member)
    {
        await TeamService.RemoveMemberAsync(TeamId, member.UserId);
        await ReloadAsync();
    }

    private async Task AssignCollectionAsync(int collectionId)
    {
        await TeamService.AssignCollectionAsync(TeamId, collectionId);
        await ReloadAsync();
    }

    private static string RoleLabel(TeamRole role) => role switch
    {
        TeamRole.TeamAdmin   => "Admin",
        TeamRole.Contributor => "Contributor",
        TeamRole.Guest       => "Guest",
        _                    => role.ToString()
    };
}
