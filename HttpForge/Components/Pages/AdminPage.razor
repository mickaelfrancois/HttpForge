@page "/admin"
@attribute [Authorize(Roles = "SuperAdmin")]
@rendermode InteractiveServer
@inject TeamService TeamService
@inject NavigationManager Navigation

<PageTitle>Admin — HttpForge</PageTitle>

<div class="admin-page">
    <h2 class="admin-page-title">Teams</h2>

    @if (_createError is not null)
    {
        <div class="auth-error">@_createError</div>
    }

    <section class="team-section">
        <h3 class="team-section-title">Create a team</h3>
        <div class="invite-form">
            <input class="team-input" placeholder="Team name" @bind="_newTeamName" @bind:event="oninput"
                   @onkeydown="OnTeamNameKey" />
            <button class="btn-primary-sm" @onclick="CreateTeamAsync"
                    disabled="@string.IsNullOrWhiteSpace(_newTeamName)">
                Create
            </button>
        </div>
    </section>

    <section class="team-section">
        <h3 class="team-section-title">All teams</h3>
        @foreach (var team in _teams)
        {
            <div class="team-member-row">
                <span class="team-name">@team.Name</span>
                <span class="team-members">@team.Members.Count member(s)</span>
                <button class="btn-sm btn-secondary" @onclick="() => ManageTeam(team.Id)">Manage</button>
                <button class="btn-sm btn-danger" @onclick="() => DeleteTeamAsync(team)">Delete</button>
            </div>
        }
        @if (_teams.Count == 0)
        {
            <p class="empty-hint">No teams yet.</p>
        }
    </section>
</div>

@code {
    private List<Team> _teams = [];
    private string _newTeamName = string.Empty;
    private string? _createError;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
        => _teams = await TeamService.GetAllTeamsAsync();

    private async Task CreateTeamAsync()
    {
        if (string.IsNullOrWhiteSpace(_newTeamName)) return;
        await TeamService.CreateTeamAsync(_newTeamName.Trim());
        _newTeamName = string.Empty;
        await ReloadAsync();
    }

    private async Task OnTeamNameKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CreateTeamAsync();
    }

    private void ManageTeam(int teamId)
        => Navigation.NavigateTo("/teams/" + teamId);

    private async Task DeleteTeamAsync(Team team)
    {
        await TeamService.DeleteTeamAsync(team.Id);
        await ReloadAsync();
    }
}
