@rendermode InteractiveServer
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AppState State
@implements IDisposable

@if (_collection is null)
{
    <div class="cs-empty">Collection introuvable.</div>
}
else
{
    var cBase = _collection.VariableSets.FirstOrDefault(s => s.IsBase);
    var cSubsets = _collection.VariableSets.Where(s => !s.IsBase).ToList();
    var activeSet = _collection.VariableSets.FirstOrDefault(s => s.Id == _collection.ActiveCollectionVariableSetId && !s.IsBase);

    <div class="cs-root">
        <div class="cs-title-row">
            <span class="cs-title-icon">📦</span>
            <h2 class="cs-title">Paramètres de @_collection.Name</h2>
        </div>

        <div class="cs-tabs">
            <button class="cs-tab @(_section == Section.Variables ? "active" : "")"
                    @onclick="() => _section = Section.Variables">Variables</button>
            <button class="cs-tab @(_section == Section.Headers ? "active" : "")"
                    @onclick="() => _section = Section.Headers">Headers par défaut</button>
        </div>

        <div class="cs-body">
            @if (_section == Section.Variables)
            {
                <div class="var-list">
                    <div class="var-list-header"><span>Base</span></div>
                    @foreach (var v in cBase?.Entries ?? [])
                    {
                        var masked = v.IsSecret && !_revealed.Contains(v.Id);
                        <div class="var-row">
                            <input placeholder="key" value="@v.Key"
                                   @oninput="e => OnEntryKeyChanged(v, e)" />
                            <input placeholder="value" type="@(masked ? "password" : "text")"
                                   value="@v.Value"
                                   @oninput="e => OnEntryValueChanged(v, e)" />
                            @if (v.IsSecret)
                            {
                                <button class="icon-btn" title="@(masked ? "Reveal" : "Hide")"
                                        @onclick="() => ToggleReveal(v)">@(masked ? "👁" : "🚫")</button>
                            }
                            <button class="icon-btn @(v.IsSecret ? "active" : "")"
                                    title="@(v.IsSecret ? "Unmark as secret" : "Mark as secret")"
                                    @onclick="() => ToggleSecret(v)">@(v.IsSecret ? "🔒" : "🔓")</button>
                            <button class="icon-btn" @onclick="() => RemoveEntry(v)">✕</button>
                        </div>
                    }
                    <button class="link-btn" @onclick="AddBaseEntry">+ add collection variable</button>
                </div>

                <div class="var-list cs-subset-block">
                    <div class="var-list-header"><span>Sub-set</span></div>
                    <div class="cs-row">
                        <select value="@(_collection.ActiveCollectionVariableSetId?.ToString() ?? "")"
                                @onchange="OnSubsetChanged">
                            <option value="">— none —</option>
                            @foreach (var s in cSubsets)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                        <button class="icon-btn" title="New sub-set" @onclick="AddSubset">+</button>
                        @if (activeSet is not null)
                        {
                            <button class="icon-btn" title="Delete sub-set"
                                    @onclick="() => DeleteSubset(activeSet)">🗑</button>
                        }
                    </div>
                    @if (activeSet is not null)
                    {
                        @foreach (var v in activeSet.Entries)
                        {
                            var masked = v.IsSecret && !_revealed.Contains(v.Id);
                            <div class="var-row">
                                <input placeholder="key" value="@v.Key"
                                       @oninput="e => OnEntryKeyChanged(v, e)" />
                                <input placeholder="value" type="@(masked ? "password" : "text")"
                                       value="@v.Value"
                                       @oninput="e => OnEntryValueChanged(v, e)" />
                                @if (v.IsSecret)
                                {
                                    <button class="icon-btn" title="@(masked ? "Reveal" : "Hide")"
                                            @onclick="() => ToggleReveal(v)">@(masked ? "👁" : "🚫")</button>
                                }
                                <button class="icon-btn @(v.IsSecret ? "active" : "")"
                                        title="@(v.IsSecret ? "Unmark as secret" : "Mark as secret")"
                                        @onclick="() => ToggleSecret(v)">@(v.IsSecret ? "🔒" : "🔓")</button>
                                <button class="icon-btn" @onclick="() => RemoveEntry(v)">✕</button>
                            </div>
                        }
                        <button class="link-btn" @onclick="() => AddSubsetEntry(activeSet.Id)">+ add variable</button>
                    }
                </div>
            }
            else
            {
                <div class="cs-headers-hint">Appliqués à toutes les requêtes de la collection.</div>
                <KeyValueGrid Items="_collection.DefaultHeaders"
                              ItemCreator="@(() => new CollectionDefaultHeader { CollectionId = _collection.Id })"
                              KeyOf="@(i => ((CollectionDefaultHeader)i).Key)"
                              ValueOf="@(i => ((CollectionDefaultHeader)i).Value)"
                              EnabledOf="@(i => ((CollectionDefaultHeader)i).Enabled)"
                              SetKey="@((i, v) => ((CollectionDefaultHeader)i).Key = v)"
                              SetValue="@((i, v) => ((CollectionDefaultHeader)i).Value = v)"
                              SetEnabled="@((i, v) => ((CollectionDefaultHeader)i).Enabled = v)"
                              OnChanged="SaveDefaultHeaderAsync"
                              OnRemove="RemoveDefaultHeaderAsync" />
            }
        </div>
    </div>
}

<ConfirmDialog Visible="_confirm.Visible"
               Message="@_confirm.Message"
               ConfirmLabel="@_confirm.ConfirmLabel"
               Danger="_confirm.Danger"
               OnConfirm="_confirm.Confirm"
               OnCancel="_confirm.Cancel" />

<PromptDialog Visible="_prompt.Visible"
              Title="@_prompt.Title"
              Message="@_prompt.Message"
              ConfirmLabel="@_prompt.ConfirmLabel"
              Placeholder="@_prompt.Placeholder"
              OnConfirm="_prompt.Submit"
              OnCancel="_prompt.Cancel" />

@code {
    private enum Section { Variables, Headers }

    [Parameter, EditorRequired] public int CollectionId { get; set; }

    private Collection? _collection;
    private int _loadedCollectionId = -1;
    private Section _section = Section.Variables;
    private readonly HashSet<int> _revealed = new();
    private readonly ConfirmState _confirm = new();
    private readonly PromptState _prompt = new();

    protected override void OnInitialized()
    {
        State.OnChange += OnStateChanged;
        _confirm.OnChange = () => InvokeAsync(StateHasChanged);
        _prompt.OnChange = () => InvokeAsync(StateHasChanged);
    }

    // Loads on first render and whenever the hosting tab targets a different collection.
    protected override async Task OnParametersSetAsync()
    {
        if (CollectionId == _loadedCollectionId) return;
        _loadedCollectionId = CollectionId;
        await ReloadAsync();
    }

    public void Dispose() => State.OnChange -= OnStateChanged;

    private async void OnStateChanged()
    {
        try
        {
            await ReloadAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[HttpForge] CollectionSettings reload error: {ex.Message}");
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReloadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _collection = await db.Collections
            .Include(c => c.VariableSets).ThenInclude(s => s.Entries)
            .Include(c => c.DefaultHeaders)
            .FirstOrDefaultAsync(c => c.Id == CollectionId);
    }

    // ── Collection variables ────────────────────────────────────────────────────

    private async Task OnEntryKeyChanged(CollectionVariableEntry v, ChangeEventArgs e)
    {
        v.Key = e.Value?.ToString() ?? "";
        await using var db = await DbFactory.CreateDbContextAsync();
        db.CollectionVariableEntries.Update(v);
        await db.SaveChangesAsync();
        State.NotifyChanged();
    }

    private async Task OnEntryValueChanged(CollectionVariableEntry v, ChangeEventArgs e)
    {
        v.Value = e.Value?.ToString() ?? "";
        await using var db = await DbFactory.CreateDbContextAsync();
        db.CollectionVariableEntries.Update(v);
        await db.SaveChangesAsync();
        State.NotifyChanged();
    }

    private async Task ToggleSecret(CollectionVariableEntry v)
    {
        v.IsSecret = !v.IsSecret;
        if (!v.IsSecret) _revealed.Remove(v.Id);
        await using var db = await DbFactory.CreateDbContextAsync();
        db.CollectionVariableEntries.Update(v);
        await db.SaveChangesAsync();
        State.NotifyChanged();
    }

    private void ToggleReveal(CollectionVariableEntry v)
    {
        if (!_revealed.Add(v.Id)) _revealed.Remove(v.Id);
        StateHasChanged();
    }

    private async Task RemoveEntry(CollectionVariableEntry v)
    {
        var label = string.IsNullOrWhiteSpace(v.Key) ? "(vide)" : v.Key;
        if (!await _confirm.AskAsync($"Supprimer la variable « {label} » ?")) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        db.CollectionVariableEntries.Remove(await db.CollectionVariableEntries.FirstAsync(x => x.Id == v.Id));
        await db.SaveChangesAsync();
        State.NotifyChanged();
        await ReloadAsync();
    }

    // Creates the (lazy) Base set on first use, mirroring the previous inline editor.
    private async Task AddBaseEntry()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var baseSet = await db.CollectionVariableSets
            .FirstOrDefaultAsync(s => s.CollectionId == CollectionId && s.IsBase);
        if (baseSet is null)
        {
            baseSet = new CollectionVariableSet { CollectionId = CollectionId, Name = "Base", IsBase = true };
            db.CollectionVariableSets.Add(baseSet);
            await db.SaveChangesAsync();
        }
        db.CollectionVariableEntries.Add(new CollectionVariableEntry { CollectionVariableSetId = baseSet.Id });
        await db.SaveChangesAsync();
        State.NotifyChanged();
        await ReloadAsync();
    }

    private async Task AddSubsetEntry(int setId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.CollectionVariableEntries.Add(new CollectionVariableEntry { CollectionVariableSetId = setId });
        await db.SaveChangesAsync();
        State.NotifyChanged();
        await ReloadAsync();
    }

    private async Task OnSubsetChanged(ChangeEventArgs e)
    {
        var id = int.TryParse(e.Value?.ToString(), out var v) ? (int?)v : null;
        await using var db = await DbFactory.CreateDbContextAsync();
        var col = await db.Collections.FirstAsync(x => x.Id == CollectionId);
        col.ActiveCollectionVariableSetId = id;
        await db.SaveChangesAsync();
        State.NotifyChanged();
    }

    private async Task AddSubset()
    {
        var name = await _prompt.AskAsync("Nom du sous-ensemble :", placeholder: "ex. Staging");
        if (string.IsNullOrWhiteSpace(name)) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var col = await db.Collections.FirstAsync(x => x.Id == CollectionId);
        var set = new CollectionVariableSet { CollectionId = CollectionId, Name = name.Trim(), IsBase = false };
        db.CollectionVariableSets.Add(set);
        await db.SaveChangesAsync();
        col.ActiveCollectionVariableSetId = set.Id;
        await db.SaveChangesAsync();
        State.NotifyChanged();
        await ReloadAsync();
    }

    private async Task DeleteSubset(CollectionVariableSet s)
    {
        var msg = s.Entries.Count > 0
            ? $"Supprimer le sous-ensemble « {s.Name} » et ses {s.Entries.Count} variable(s) ?"
            : $"Supprimer le sous-ensemble « {s.Name} » ?";
        if (!await _confirm.AskAsync(msg)) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        db.CollectionVariableSets.Remove(await db.CollectionVariableSets.FirstAsync(x => x.Id == s.Id));
        var col = await db.Collections.FirstAsync(x => x.Id == CollectionId);
        // A deleted active sub-set falls back to "none" (base only), never a dangling id.
        if (col.ActiveCollectionVariableSetId == s.Id) col.ActiveCollectionVariableSetId = null;
        await db.SaveChangesAsync();
        State.NotifyChanged();
        await ReloadAsync();
    }

    // ── Collection default headers (reuses KeyValueGrid) ────────────────────────

    // KeyValueGrid raises OnChanged for both a freshly added row and an edited one, so
    // upsert on the identity: Id == 0 means the in-memory row is not persisted yet.
    private async Task SaveDefaultHeaderAsync(object item)
    {
        var h = (CollectionDefaultHeader)item;
        await using var db = await DbFactory.CreateDbContextAsync();
        if (h.Id == 0) db.CollectionDefaultHeaders.Add(h);
        else db.CollectionDefaultHeaders.Update(h);
        await db.SaveChangesAsync();
        State.NotifyChanged();
    }

    private async Task RemoveDefaultHeaderAsync(object item)
    {
        var h = (CollectionDefaultHeader)item;
        _collection?.DefaultHeaders.Remove(h);
        if (h.Id != 0)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.CollectionDefaultHeaders.Remove(h);
            await db.SaveChangesAsync();
        }
        State.NotifyChanged();
    }

}
