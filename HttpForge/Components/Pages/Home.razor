    // ── Save + modal handlers ─────────────────────────────────────────────────

    private Task SaveDraftAsync(bool forceOverwrite)
    {
        var tab = Active;
        return tab is null ? Task.CompletedTask : SaveTabAsync(tab, forceOverwrite, isAuto: false);
    }

    // Saves a specific tab's draft. Targets the passed tab (not Active) so a debounced
    // auto-save that lands after a tab switch always writes the draft it was armed for.
    private async Task SaveTabAsync(TabState tab, bool forceOverwrite, bool isAuto)
    {
        // Auto-save only writes when there is something to write; a manual Save always runs.
        if (isAuto && !tab.Draft.IsDirty) return;

        tab.IsAutoSaving = true;
        var result = await SaveService.SaveAsync(tab.Draft, _originId, forceOverwrite);

        if (result.IsConflict)
        {
            tab.IsAutoSaving = false;
            // Auto-save must never overwrite another window's change: suspend this tab's
            // timer (so it doesn't loop) and surface the existing conflict modal. Make the
            // conflicting tab active so the modal's Écraser/Annuler act on it.
            if (isAuto)
            {
                AutoSaver.Suspend(tab.RequestId);
                if (!ReferenceEquals(Active, tab)) Tabs.ActivateTab(tab.RequestId);
            }
            _conflictAt = result.ConflictAt;
            _showConflictModal = true;
            return;
        }

        // Rebase the draft onto the version we just wrote so the next save doesn't falsely
        // conflict with this one, then drop any pending timer (the draft is now clean).
        if (result.SavedAt is DateTime savedAt)
        {
            tab.Draft.LoadedAt = savedAt;
            tab.LastSavedAt = savedAt;
        }
        tab.Draft.ClearDirty();
        tab.IsAutoSaving = false;
        AutoSaver.Cancel(tab.RequestId);

        if (ReferenceEquals(Active, tab))
            await LoadActiveTabContextAsync();
    }

    private async Task OnSaveOverwriteAsync()
    {
        _showConflictModal = false;
        // Conflict resolved: re-enable auto-save so future edits re-arm the debounce.
        if (Active is not null) AutoSaver.Resume(Active.RequestId);
        await SaveDraftAsync(forceOverwrite: true);
    }

    private void OnCancelSave()
    {
        _showConflictModal = false;
        // Leave the draft dirty, but re-enable auto-save so the next edit can retry.
        if (Active is not null) AutoSaver.Resume(Active.RequestId);
    }

    private async Task SaveAndCloseAsync()
    {
        _showUnsavedModal = false;
        if (_pendingCloseTabId is not int id) return;
        var tab = Tabs.Tabs.FirstOrDefault(t => t.RequestId == id);
        if (tab is null) { _pendingCloseTabId = null; return; }

        var result = await SaveService.SaveAsync(tab.Draft, _originId, false);
        if (result.IsConflict)
        {
            Tabs.ActivateTab(id);
            _conflictAt = result.ConflictAt;
            _showConflictModal = true;
            _pendingCloseTabId = null;
            return;
        }
        tab.Draft.ClearDirty();

        Tabs.ForceCloseTab(id);
        _pendingCloseTabId = null;
    }

    private void DiscardAndClose()
    {
        if (_pendingCloseTabId is int id)
        {
            Tabs.ForceCloseTab(id);
            _pendingCloseTabId = null;
        }
        _showUnsavedModal = false;
    }

    private void CancelClose()
    {
        _pendingCloseTabId = null;
        _showUnsavedModal = false;
    }

    private async Task OnReloadFromServerAsync()
    {
        _reloadToast = null;
        var tab = Active;
        if (tab is not null)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var fresh = await db.Requests
                .Include(r => r.Headers)
                .Include(r => r.QueryParams)
                .Include(r => r.FormFields)
                .Include(r => r.Variables)
                .FirstOrDefaultAsync(r => r.Id == tab.RequestId);
            if (fresh is not null)
            {
                tab.Draft = RequestDraft.FromRequest(fresh, DateTime.UtcNow);
                tab.Name = fresh.Name;
                tab.Method = fresh.Method.ToString();
            }
        }
        await LoadActiveTabContextAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void OnDismissToast()
    {
        _reloadToast = null;
    }

    // Invoked by the singleton notifier on the *saving* circuit's thread. Marshal
    // everything onto this circuit's renderer before reading scoped state (Active),
    // so we never touch another circuit's TabManagerService off-thread.
    private Task OnRequestSavedByOther(int requestId, string originId)
        => InvokeAsync(() =>
        {
            if (requestId == Active?.RequestId && originId != _originId)
            {
                _reloadToast = "Cette requête a été modifiée dans une autre fenêtre.";
                StateHasChanged();
            }
        });

    // ── Send ──────────────────────────────────────────────────────────────────

    private async Task SendAsync()
    {
        var tab = Active;
        if (tab is null || _request is null) return;

        // Send the editor content as-is (Postman-style): the request is materialized
        // from the draft without saving it, so the draft stays dirty and the Save
        // button remains visible after Send.
        var request = tab.Draft.ToTransientRequest();

        // Resolve against the draft's request-level variables (not the saved ones)
        // so unsaved variable edits apply to this send.
        var resolvedVariables = State.BuildVariables(
            _globalBase, _globalSubset, _collectionBase, _collectionSubset,
            request);

        var vars = resolvedVariables.ToDictionary(
            v => v.Key,
            v => v.Value,
            StringComparer.OrdinalIgnoreCase);
        var activeCollectionSetId = (_collectionSubset ?? _collectionBase)?.Id;
        var activeGlobalEnvId = (_globalSubset ?? _globalBase)?.Id;

        var cts = new CancellationTokenSource();
        tab.SendCts = cts;
        tab.IsSending = true;
        tab.Result = null;
        tab.ScriptResult = null;
        StateHasChanged();

        // Collection default headers are inherited at send time; the request's own headers
        // override them by key (case-insensitive) inside RequestExecutor.
        var defaultHeaders = _collectionDefaultHeaders
            .Select(h => new HeaderInput(h.Key, h.Value, h.Enabled))
            .ToList();

        try
        {
            var result = await Executor.ExecuteAsync(request, vars, defaultHeaders, cts.Token);
            tab.Result = result;

            if (result.Error is null && !string.IsNullOrWhiteSpace(request.PostScript))
            {
                if (!request.PostScriptTrusted)
                {
                    // Untrusted (imported) script: do not execute. Surface a notice so the
                    // user knows it was skipped and how to enable it after reviewing.
                    tab.ScriptResult = new ScriptResult(
                        new ScriptMutations([], [], []),
                        [],
                        "Le script importé est désactivé. Ouvrez l'onglet Scripts, vérifiez son contenu puis cliquez sur « Activer le script » pour l'exécuter.");
                }
                else
                {
                    var scriptResult = await ScriptRunner.RunPostScriptAsync(
                        request,
                        result,
                        activeCollectionSetId,
                        activeGlobalEnvId,
                        resolvedVariables);

                    tab.ScriptResult = scriptResult;

                    if (scriptResult is not null && ReferenceEquals(Active, tab))
                        ApplyScriptMutationsToMemory(scriptResult);
                }
            }
        }
        catch (OperationCanceledException)
        {
            // User cancelled — leave the response pane cleared (tab.Result stays null).
        }
        finally
        {
            tab.IsSending = false;
            cts.Dispose();
            tab.SendCts = null;
            StateHasChanged();
        }
    }

    private void CancelSend()
    {
        Active?.SendCts?.Cancel();
    }

    // ── Empty-state actions ─────────────────────────────────────────────────────

    // Creates a blank request and opens it — the empty-state "Nouvelle requête" CTA.
    private async Task NewRequestAsync()
    {
        var id = await CreateRequestAsync("New request");
        if (id is not null) await Tabs.OpenTabAsync(id.Value);
    }

    // Creates a request in the selected collection, or the first one, or a brand-new
    // collection when none exist yet. Notifies so NavMenu reveals it. Returns the new id;
    // the caller decides whether to open a tab.
    private async Task<int?> CreateRequestAsync(string name)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var collectionId = State.SelectedCollectionId is int sel
                           && await db.Collections.AnyAsync(c => c.Id == sel)
            ? sel
            : await db.Collections.OrderBy(c => c.Name).Select(c => (int?)c.Id).FirstOrDefaultAsync();

        if (collectionId is null)
        {
            var created = new Collection { Name = "Ma collection" };
            db.Collections.Add(created);
            await db.SaveChangesAsync();
            collectionId = created.Id;
        }

        var request = new HttpRequestItem
        {
            CollectionId = collectionId.Value,
            Name = string.IsNullOrWhiteSpace(name) ? "New request" : name,
            Method = HttpMethodKind.GET,
            Url = "https://"
        };
        db.Requests.Add(request);
        await db.SaveChangesAsync();
        State.NotifyChanged();
        return request.Id;
    }

    // A readable request name derived from a cURL URL (last path segment, else host).
    private static string NameFromUrl(string url)
    {
        if (!string.IsNullOrWhiteSpace(url) && Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            var seg = uri.Segments.LastOrDefault(s => s.Trim('/').Length > 0)?.Trim('/');
            return string.IsNullOrEmpty(seg) ? uri.Host : seg;
        }
        return "New request";
    }

    // ── cURL import / export ───────────────────────────────────────────────────

    // Applies a pasted cURL command to a request. From the empty state (no active tab) a
    // fresh request is created and opened first, so paste-to-import works cold.
    private async Task ImportCurlAsync(string curl)
    {
        _showCurlImport = false;
        var parsed = Curl.Parse(curl);

        if (Active is null)
        {
            var newId = await CreateRequestAsync(NameFromUrl(parsed.Url));
            if (newId is null) return;
            await Tabs.OpenTabAsync(newId.Value);
        }

        if (Active is not { Kind: TabKind.Request } tab) return;

        // A NEW draft instance is assigned (not mutated) so the @key="tab.Draft" subtree —
        // including the CodeMirror body editor — re-initializes with the imported content.
        tab.Draft = BuildDraftFromCurl(tab.Draft, parsed);
        tab.Method = parsed.Method.ToString();
        MarkDirtyAndSchedule(tab);

        _curlNotice = parsed.Warnings.Count > 0
            ? "cURL importé — avertissements : " + string.Join(" ; ", parsed.Warnings)
            : "cURL importé.";

        await InvokeAsync(StateHasChanged);
    }

    // Builds a fresh draft from a parsed cURL, preserving the request's identity and its
    // script/variables (which don't come from the cURL).
    private static RequestDraft BuildDraftFromCurl(RequestDraft old, CurlParseResult parsed) => new()
    {
        RequestId = old.RequestId,
        LoadedAt = old.LoadedAt,
        Name = old.Name,
        Method = parsed.Method,
        Url = parsed.Url,
        BodyKind = parsed.BodyKind,
        BodyContent = parsed.Body,
        PostScript = old.PostScript,
        PostScriptTrusted = old.PostScriptTrusted,
        IgnoreTlsErrors = old.IgnoreTlsErrors || parsed.IgnoreTlsErrors,
        Headers = parsed.Headers
            .Select(h => new HeaderItem { HttpRequestItemId = old.RequestId, Key = h.Key, Value = h.Value, Enabled = true })
            .ToList(),
        // The parsed URL keeps its query string inline, so start from no separate params
        // (avoids duplicating the query when the request is sent).
        QueryParams = [],
        FormFields = parsed.FormFields
            .Select(f => new FormFieldItem { HttpRequestItemId = old.RequestId, Key = f.Key, Value = f.Value, Enabled = true })
            .ToList(),
        Variables = old.Variables.ToList()
    };

    // Builds a cURL command from the active draft and copies it to the clipboard. Uses the
    // resolved URL and the request/collection header merge (mirroring RequestExecutor);
    // VariablePreview.Resolve keeps secret variables masked as {{name}} so they never leak.
    private async Task CopyAsCurlAsync()
    {
        if (Active is not { Kind: TabKind.Request } tab) return;
        var d = tab.Draft;

        var url = VariablePreview.BuildFullUrl(d.Url, d.QueryParams, _resolvedVariables);

        var merged = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var order = new List<string>();
        void Put(string key, string value)
        {
            if (!merged.ContainsKey(key)) order.Add(key);
            merged[key] = value;
        }
        foreach (var h in _collectionDefaultHeaders.Where(h => h.Enabled && !string.IsNullOrWhiteSpace(h.Key)))
            Put(h.Key, h.Value);
        foreach (var h in d.Headers.Where(h => h.Enabled && !string.IsNullOrWhiteSpace(h.Key)))
            Put(h.Key, h.Value);

        var headers = order
            .Select(k => new CurlHeader(
                VariablePreview.Resolve(k, _resolvedVariables),
                VariablePreview.Resolve(merged[k], _resolvedVariables)))
            .ToList();

        var formFields = d.FormFields
            .Where(f => f.Enabled && !string.IsNullOrWhiteSpace(f.Key))
            .Select(f => new CurlFormField(
                VariablePreview.Resolve(f.Key, _resolvedVariables),
                VariablePreview.Resolve(f.Value, _resolvedVariables)))
            .ToList();

        var resolvedBody = VariablePreview.Resolve(d.BodyContent, _resolvedVariables);
        var body = string.IsNullOrEmpty(resolvedBody) ? d.BodyContent : resolvedBody;

        var command = Curl.Build(new CurlExportRequest(d.Method, url, headers, d.BodyKind, body, formFields));

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", command);
            _curlNotice = "Commande cURL copiée dans le presse-papier.";
        }
        catch
        {
            _curlNotice = "Copie impossible (presse-papier indisponible).";
        }
        await InvokeAsync(StateHasChanged);
    }

    // ── Keyboard shortcuts (invoked from forge.shortcuts) ──────────────────────

    // Ctrl/Cmd+Enter — send the active request. No-op if the active tab isn't a request
    // or a send is already in flight (SendAsync also guards on _request being loaded).
    [JSInvokable]
    public async Task SendShortcut()
    {
        if (Active is not { Kind: TabKind.Request } tab || tab.IsSending) return;
        await SendAsync();
    }

    // Ctrl/Cmd+Save — save the active draft. No-op when nothing changed; the browser's
    // own save dialog is already suppressed (preventDefault) on the JS side.
    [JSInvokable]
    public async Task SaveShortcut()
    {
        if (Active is not { Kind: TabKind.Request } tab || !tab.Draft.IsDirty) return;
        await SaveDraftAsync(forceOverwrite: false);
    }

    private void ApplyScriptMutationsToMemory(ScriptResult result)
    {
        foreach (var (key, value) in result.Mutations.Request)
        {
            var existing = _request?.Variables.FirstOrDefault(v =>
                string.Equals(v.Key, key, StringComparison.OrdinalIgnoreCase));
            if (existing is not null)
                existing.Value = value;
            else if (_request is not null)
                _request.Variables.Add(new RequestVariable
                    { HttpRequestItemId = _request.Id, Key = key, Value = value });

            // Sync the draft too: Send resolves variables from the draft, so a script
            // mutation must land there to apply on the next send. The value was already
            // persisted by ScriptRunner, so this does not mark the draft dirty.
            var draft = Active?.Draft;
            if (draft is null) continue;
            var draftVar = draft.Variables.FirstOrDefault(v =>
                string.Equals(v.Key, key, StringComparison.OrdinalIgnoreCase));
            if (draftVar is not null)
                draftVar.Value = value;
            else
                draft.Variables.Add(new RequestVariable
                    { HttpRequestItemId = draft.RequestId, Key = key, Value = value });
        }

        foreach (var (key, value) in result.Mutations.Collection)
        {
            var target = _collectionSubset ?? _collectionBase;
            var existing = target?.Entries.FirstOrDefault(e =>
                string.Equals(e.Key, key, StringComparison.OrdinalIgnoreCase));
            if (existing is not null)
                existing.Value = value;
            else
                target?.Entries.Add(new CollectionVariableEntry
                    { CollectionVariableSetId = target.Id, Key = key, Value = value });
        }

        foreach (var (key, value) in result.Mutations.Global)
        {
            var target = _globalSubset ?? _globalBase;
            var existing = target?.Variables.FirstOrDefault(v =>
                string.Equals(v.Key, key, StringComparison.OrdinalIgnoreCase));
            if (existing is not null)
                existing.Value = value;
            else
                target?.Variables.Add(new EnvironmentVariable
                    { AppEnvironmentId = target.Id, Key = key, Value = value });
        }

        RebuildVariables();
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static string StatusClass(int code) => code switch
    {
        >= 200 and < 300 => "2xx",
        >= 300 and < 400 => "3xx",
        >= 400 and < 500 => "4xx",
        >= 500 => "5xx",
        _ => "0xx"
    };

    private static string FormatBody(string body)
    {
        if (string.IsNullOrWhiteSpace(body)) return string.Empty;
        var trimmed = body.TrimStart();
        if (trimmed.StartsWith('{') || trimmed.StartsWith('['))
        {
            try
            {
                using var doc = System.Text.Json.JsonDocument.Parse(body);
                return System.Text.Json.JsonSerializer.Serialize(doc.RootElement,
                    new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            }
            catch { }
        }
        return body;
    }

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";

    // An inherited (collection-default) header is overridden when the request defines an
    // enabled header with the same key (case-insensitive) — mirrors RequestExecutor's merge.
    private static bool IsInheritedHeaderOverridden(RequestDraft draft, string key) =>
        draft.Headers.Any(rh => rh.Enabled && string.Equals(rh.Key, key, StringComparison.OrdinalIgnoreCase));

    private static int Pct(long part, long total) =>
        total <= 0 ? 0 : (int)Math.Round(100.0 * part / total);

    private static IEnumerable<(string Key, string Label, long Ms)> TimingPhases(RequestTiming t)
    {
        yield return ("dns", "DNS", t.DnsMs);
        yield return ("connect", "TCP", t.ConnectMs);
        yield return ("tls", "TLS", t.TlsMs);
        yield return ("wait", "Waiting (TTFB)", t.WaitingMs);
        yield return ("download", "Download", t.DownloadMs);
    }

    // Guard on Kind, not just null: a CollectionSettings tab has a null Draft, so `Active?.`
    // alone would NRE. Mirrors TabManagerService.SyncActiveSelection's explicit Kind test.
    private int TabBadgeCount(string subTab)
    {
        if (Active is not { Kind: TabKind.Request } tab) return 0;
        return subTab switch
        {
            "Params"    => tab.Draft.QueryParams.Count(p => p.Enabled && !string.IsNullOrWhiteSpace(p.Key)),
            "Headers"   => tab.Draft.Headers.Count(h => !string.IsNullOrWhiteSpace(h.Key)),
            "Variables" => tab.Draft.Variables.Count,
            _           => 0
        };
    }

    private bool TabHasDot(string subTab)
    {
        if (Active is not { Kind: TabKind.Request } tab) return false;
        return subTab switch
        {
            "Body"    => !string.IsNullOrWhiteSpace(tab.Draft.BodyContent),
            "Scripts" => !string.IsNullOrWhiteSpace(tab.Draft.PostScript),
            "Options" => tab.Draft.IgnoreTlsErrors,
            _         => false
        };
    }
