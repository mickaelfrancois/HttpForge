@page "/"
@rendermode InteractiveServer
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AppState State
@inject RequestExecutor Executor
@inject ScriptRunner ScriptRunner
@inject IJSRuntime JS
@inject RequestSaveService SaveService
@inject RequestAutoSaver AutoSaver
@inject RequestChangeNotifier Notifier
@inject TabManagerService Tabs
@inject CurlService Curl
@using HttpForge.Models
@using HttpForge.Services
@implements IAsyncDisposable

<PageTitle>HttpForge</PageTitle>

<TabBar />

@if (Active is null)
{
    <div class="empty-state">
        <div class="empty-mark">⚡</div>
        <h2>HttpForge</h2>
        <p>
            @(_hasCollections
                ? "Sélectionnez une requête à gauche, ou créez-en une nouvelle."
                : "Créez votre première requête pour démarrer.")
        </p>
        <div class="empty-actions">
            <button class="empty-action empty-action--primary" @onclick="NewRequestAsync">＋ Nouvelle requête</button>
            <button class="empty-action" @onclick="() => _showCurlImport = true">⇤ Coller cURL</button>
            <button class="empty-action" @onclick="() => State.RequestOpenImport()">↓ Importer…</button>
        </div>
    </div>
}
else if (Active.Kind == TabKind.CollectionSettings)
{
    @* Keyed by tab identity so switching between two collection-settings tabs recreates
       the component with the new CollectionId instead of reusing stale state. *@
    <CollectionSettings CollectionId="Active.CollectionId" @key="Active.Key" />
}
else
{
    var tab = Active!;

    @if (_reloadToast is not null)
    {
        <div class="reload-toast">
            @_reloadToast
            <button @onclick="OnReloadFromServerAsync">Recharger</button>
            <button @onclick="OnDismissToast">Ignorer</button>
        </div>
    }

    @if (_curlNotice is not null)
    {
        <div class="curl-notice">
            <span>@_curlNotice</span>
            <button title="Fermer" @onclick="() => _curlNotice = null">✕</button>
        </div>
    }

    @* Keyed on the Draft *instance*: switching tabs (different draft) or reloading from
       server (replaced draft) recreates the whole subtree, so CodeMirror editors are
       re-initialized with the new tab's content instead of silently keeping the old one. *@
    <div class="editor" @key="tab.Draft">
        <div class="request-name-row">
            <input class="request-name-input" value="@tab.Draft.Name"
                   @oninput="OnNameInput" placeholder="Request name" />
        </div>
        <div class="url-bar">
            <select class="method-select method-@tab.Draft.Method.ToString().ToLower()"
                    @onchange="OnMethodChanged">
                @foreach (var m in Enum.GetValues<HttpMethodKind>())
                {
                    <option value="@m" selected="@(tab.Draft.Method == m)">@m</option>
                }
            </select>
            <VariableInput Value="@tab.Draft.Url"
                           ValueChanged="OnUrlChanged"
                           CssClass="url-input"
                           Placeholder="https://api.example.com/path"
                           Title="@Tooltip(tab.Draft.Url)"
                           EnvVariables="_resolvedVariables" />
            @if (tab.IsSending)
            {
                <button class="cancel-btn" @onclick="CancelSend">Cancel</button>
            }
            else
            {
                <button class="send-btn" @onclick="SendAsync">Send</button>
            }
            @if (tab.Draft.IsDirty)
            {
                <button class="save-btn" @onclick="() => SaveDraftAsync(false)">Save</button>
            }
            <button class="curl-btn" title="Copier la requête comme commande cURL"
                    @onclick="CopyAsCurlAsync">⎘ cURL</button>
            <button class="curl-btn" title="Remplacer la requête depuis une commande cURL"
                    @onclick="() => _showCurlImport = true">⇤ cURL</button>
            <span class="autosave-status">
                @if (tab.IsAutoSaving)
                {
                    <text>Enregistrement…</text>
                }
                else if (!tab.Draft.IsDirty && tab.LastSavedAt is DateTime savedAt)
                {
                    <text>Enregistré à @savedAt.ToLocalTime().ToString("HH:mm:ss")</text>
                }
            </span>
        </div>

        @{
            var _hasParams = tab.Draft.QueryParams.Any(p => p.Enabled && !string.IsNullOrWhiteSpace(p.Key));
            var _showPreview = !string.IsNullOrWhiteSpace(tab.Draft.Url) && (tab.Draft.Url.Contains("{{") || _hasParams);
            var _previewUrl = _showPreview ? VariablePreview.BuildFullUrl(tab.Draft.Url, tab.Draft.QueryParams, _resolvedVariables) : string.Empty;
        }
        @if (_showPreview)
        {
            <div class="url-preview-panel">
                <div class="url-preview-header">
                    <span>Resolved URL</span>
                    <button class="url-preview-copy" title="Copy URL" @onclick="() => CopyUrlAsync(_previewUrl)">⎘ Copy</button>
                </div>
                <div class="url-preview">@_previewUrl</div>
            </div>
        }

        <div class="tabs">
            @foreach (var t in _subTabs)
            {
                <button class="tab @(t == tab.ActiveSubTab ? "active" : "")" @onclick="() => tab.ActiveSubTab = t">
                    @t
                    @{ var _badge = TabBadgeCount(t); }
                    @if (_badge > 0) { <span class="tab-badge">@_badge</span> }
                    @if (TabHasDot(t)) { <span class="tab-dot"></span> }
                </button>
            }
        </div>

        <div class="tab-body">
            @switch (tab.ActiveSubTab)
            {
                case "Params":
                    <KeyValueGrid Items="tab.Draft.QueryParams"
                                  ItemCreator="@(() => new QueryParamItem { HttpRequestItemId = tab.Draft.RequestId })"
                                  KeyOf="@(i => ((QueryParamItem)i).Key)"
                                  ValueOf="@(i => ((QueryParamItem)i).Value)"
                                  EnabledOf="@(i => ((QueryParamItem)i).Enabled)"
                                  SetKey="@((i, v) => ((QueryParamItem)i).Key = v)"
                                  SetValue="@((i, v) => ((QueryParamItem)i).Value = v)"
                                  SetEnabled="@((i, v) => ((QueryParamItem)i).Enabled = v)"
                                  OnChanged="SaveQueryParamAsync"
                                  OnRemove="RemoveQueryParamAsync"
                                  EnvVariables="_resolvedVariables" />
                    break;
                case "Headers":
                    var inheritedHeaders = _collectionDefaultHeaders
                        .Where(h => h.Enabled && !string.IsNullOrWhiteSpace(h.Key))
                        .ToList();
                    if (inheritedHeaders.Count > 0)
                    {
                        <div class="inherited-headers">
                            <div class="inherited-headers-title">Headers hérités de la collection (lecture seule)</div>
                            @foreach (var h in inheritedHeaders)
                            {
                                <div class="inherited-header @(IsInheritedHeaderOverridden(tab.Draft, h.Key) ? "inherited-header--overridden" : "")">
                                    <span class="inherited-header-key">@h.Key</span>
                                    <span class="inherited-header-value" title="@Tooltip(h.Value)">@h.Value</span>
                                    @if (IsInheritedHeaderOverridden(tab.Draft, h.Key))
                                    {
                                        <span class="inherited-header-badge" title="Écrasé par un header de cette requête">écrasé</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                    <KeyValueGrid Items="tab.Draft.Headers"
                                  ItemCreator="@(() => new HeaderItem { HttpRequestItemId = tab.Draft.RequestId })"
                                  KeyOf="@(i => ((HeaderItem)i).Key)"
                                  ValueOf="@(i => ((HeaderItem)i).Value)"
                                  EnabledOf="@(i => ((HeaderItem)i).Enabled)"
                                  SetKey="@((i, v) => ((HeaderItem)i).Key = v)"
                                  SetValue="@((i, v) => ((HeaderItem)i).Value = v)"
                                  SetEnabled="@((i, v) => ((HeaderItem)i).Enabled = v)"
                                  OnChanged="SaveHeaderAsync"
                                  OnRemove="RemoveHeaderAsync"
                                  EnvVariables="_resolvedVariables" />
                    break;
                case "Body":
                    <div class="body-editor">
                        <div class="body-kind-row">
                            @foreach (var bk in Enum.GetValues<BodyKind>())
                            {
                                <label class="radio">
                                    <input type="radio" name="bodykind"
                                           checked="@(tab.Draft.BodyKind == bk)"
                                           @onchange="@(_ => OnBodyKindChanged(bk))" />
                                    @bk
                                </label>
                            }
                        </div>
                        @if (tab.Draft.BodyKind == BodyKind.Json)
                        {
                            <JsonBodyEditor Value="@tab.Draft.BodyContent"
                                            ValueChanged="@(v => OnBodyChanged(tab, v))" />
                        }
                        else if (tab.Draft.BodyKind == BodyKind.Raw)
                        {
                            <VariableInput Value="@tab.Draft.BodyContent"
                                           ValueChanged="@(v => OnBodyChanged(tab, v))"
                                           Multiline="true"
                                           CssClass="body-textarea"
                                           Placeholder="raw body"
                                           Title="@Tooltip(tab.Draft.BodyContent)"
                                           EnvVariables="_resolvedVariables" />
                        }
                        else if (tab.Draft.BodyKind == BodyKind.FormUrlEncoded)
                        {
                            <KeyValueGrid Items="tab.Draft.FormFields"
                                          ItemCreator="@(() => new FormFieldItem { HttpRequestItemId = tab.Draft.RequestId })"
                                          KeyOf="@(i => ((FormFieldItem)i).Key)"
                                          ValueOf="@(i => ((FormFieldItem)i).Value)"
                                          EnabledOf="@(i => ((FormFieldItem)i).Enabled)"
                                          SetKey="@((i, v) => ((FormFieldItem)i).Key = v)"
                                          SetValue="@((i, v) => ((FormFieldItem)i).Value = v)"
                                          SetEnabled="@((i, v) => ((FormFieldItem)i).Enabled = v)"
                                          OnChanged="SaveFormFieldAsync"
                                          OnRemove="RemoveFormFieldAsync"
                                          EnvVariables="_resolvedVariables" />
                        }
                        else
                        {
                            <div class="empty-hint">No body will be sent.</div>
                        }
                    </div>
                    break;
                case "Variables":
                    <KeyValueGrid Items="tab.Draft.Variables"
                                  ItemCreator="@(() => new RequestVariable { HttpRequestItemId = tab.Draft.RequestId })"
                                  KeyOf="@(i => ((RequestVariable)i).Key)"
                                  ValueOf="@(i => ((RequestVariable)i).Value)"
                                  EnabledOf="@(_ => true)"
                                  SetKey="@((i, v) => { ((RequestVariable)i).Key = v; MarkDirtyAndSchedule(tab); })"
                                  SetValue="@((i, v) => { ((RequestVariable)i).Value = v; MarkDirtyAndSchedule(tab); })"
                                  SetEnabled="@((i, v) => { })"
                                  OnChanged="OnRequestVarChangedAsync"
                                  OnRemove="RemoveRequestVarAsync"
                                  EnvVariables="_resolvedVariables" />
                    break;
                case "Scripts":
                    <div class="scripts-tab">
                        <div class="script-section-label">Post-request script</div>
                        @if (!tab.Draft.PostScriptTrusted && !string.IsNullOrWhiteSpace(tab.Draft.PostScript))
                        {
                            <div class="script-untrusted-warning">
                                <span>⚠ Ce script a été importé et est <strong>désactivé</strong> pour des raisons de sécurité. Vérifiez son contenu ci-dessous, puis activez-le si vous lui faites confiance.</span>
                                <button class="btn-enable-script"
                                        @onclick="EnableScriptAsync">Activer le script</button>
                            </div>
                        }
                        <ScriptEditor Value="@tab.Draft.PostScript"
                                      ValueChanged="@(v => OnPostScriptChanged(tab, v))" />
                        <div class="script-hint">
                            Use <code>fg.response.json()</code>, <code>fg.variables.set("key", value)</code>.
                            <code>async/await</code> supported.
                        </div>
                    </div>
                    break;
                case "Options":
                    <div class="options-tab">
                        <label class="tls-toggle">
                            <input type="checkbox"
                                   checked="@tab.Draft.IgnoreTlsErrors"
                                   @onchange="OnIgnoreTlsChanged" />
                            <span>Ignorer les erreurs de certificat TLS</span>
                        </label>
                        <div class="options-hint">
                            ⚠ Désactive la validation du certificat (autorité, nom d'hôte, expiration)
                            pour cette requête. À n'utiliser que sur des services de confiance.
                        </div>
                    </div>
                    break;
            }
        </div>

        <div class="response-pane">
            @if (tab.IsSending)
            {
                <div class="response-loading">
                    <span class="spinner"></span>
                    <span>Envoi de la requête…</span>
                </div>
            }
            else if (tab.Result is null)
            {
                <div class="response-empty">No response yet. Click <b>Send</b>.</div>
            }
            else if (tab.Result.Error is not null)
            {
                <div class="response-error">
                    <strong>Error:</strong> @tab.Result.Error
                </div>
            }
            else
            {
                <div class="response-meta">
                    <span class="status status-@StatusClass(tab.Result.StatusCode)">@tab.Result.StatusCode @tab.Result.ReasonPhrase</span>
                    <span>⏱ @tab.Result.ElapsedMs ms</span>
                    <span>📦 @tab.Result.BodyBytes B</span>
                    <button class="tab @(tab.ActiveResponseTab == "Body" ? "active" : "")" @onclick="@(() => tab.ActiveResponseTab = "Body")">Body</button>
                    <button class="tab @(tab.ActiveResponseTab == "Headers" ? "active" : "")" @onclick="@(() => tab.ActiveResponseTab = "Headers")">Headers (@tab.Result.Headers.Count)</button>
                    @if (tab.Result.Timing is not null)
                    {
                        <button class="tab @(tab.ActiveResponseTab == "Timing" ? "active" : "")" @onclick="@(() => tab.ActiveResponseTab = "Timing")">Timing</button>
                    }
                    @if (tab.ScriptResult is not null)
                    {
                        <button class="tab @(tab.ActiveResponseTab == "Script" ? "active" : "")" @onclick="@(() => tab.ActiveResponseTab = "Script")">
                            <span class="script-tab-icon @(tab.ScriptResult.Error is null ? "script-tab-icon--ok" : "script-tab-icon--error")">
                                @(tab.ScriptResult.Error is null ? "✓" : "✗")
                            </span>
                            Script
                        </button>
                    }
                </div>
                <div class="response-body">
                    @if (tab.ActiveResponseTab == "Timing" && tab.Result.Timing is { } tm)
                    {
                        <div class="timing-pane">
                            @{ var _tot = Math.Max(1, tm.TotalMs); }
                            <div class="timing-waterfall">
                                @foreach (var phase in TimingPhases(tm))
                                {
                                    <div class="timing-row">
                                        <span class="timing-label">@phase.Label</span>
                                        <div class="timing-track">
                                            <span class="timing-seg seg-@phase.Key" style="width:@Pct(phase.Ms, _tot)%"></span>
                                        </div>
                                        <span class="timing-ms">@phase.Ms ms</span>
                                    </div>
                                }
                            </div>
                            <table class="timing-table">
                                <tr><th>HTTP</th><td>HTTP/@tm.HttpVersion</td></tr>
                                <tr><th>TLS</th><td>@(string.IsNullOrEmpty(tm.TlsProtocol) ? "—" : tm.TlsProtocol)</td></tr>
                                <tr><th>Cipher</th><td>@(string.IsNullOrEmpty(tm.TlsCipher) ? "—" : tm.TlsCipher)</td></tr>
                                <tr><th>ALPN</th><td>@(string.IsNullOrEmpty(tm.NegotiatedAlpn) ? "—" : tm.NegotiatedAlpn)</td></tr>
                                <tr><th>Total</th><td>@tm.TotalMs ms</td></tr>
                            </table>
                        </div>
                    }
                    else if (tab.ActiveResponseTab == "Headers")
                    {
                        <table class="header-table">
                            @foreach (var h in tab.Result.Headers.OrderBy(h => h.Key))
                            {
                                <tr><th>@h.Key</th><td>@h.Value</td></tr>
                            }
                        </table>
                    }
                    else if (tab.ActiveResponseTab == "Script" && tab.ScriptResult is { } sr)
                    {
                        <div class="script-result @(sr.Error is null ? "script-result--ok" : "script-result--error")">
                            <div class="script-result-header">
                                @if (sr.Error is null)
                                {
                                    <span>&#10003; Post-request script</span>
                                }
                                else
                                {
                                    <span>&#10007; Script error: @sr.Error</span>
                                }
                            </div>
                            @if (sr.Mutations.Request.Count > 0 ||
                                 sr.Mutations.Collection.Count > 0 ||
                                 sr.Mutations.Global.Count > 0)
                            {
                                <ul class="script-mutations">
                                    @foreach (var (k, v) in sr.Mutations.Request)
                                    {
                                        <li>request[<b>@k</b>] &#8592; <span class="mutation-val">@Truncate(v, 60)</span></li>
                                    }
                                    @foreach (var (k, v) in sr.Mutations.Collection)
                                    {
                                        <li>collection[<b>@k</b>] &#8592; <span class="mutation-val">@Truncate(v, 60)</span></li>
                                    }
                                    @foreach (var (k, v) in sr.Mutations.Global)
                                    {
                                        <li>global[<b>@k</b>] &#8592; <span class="mutation-val">@Truncate(v, 60)</span></li>
                                    }
                                </ul>
                            }
                            @foreach (var log in sr.Logs)
                            {
                                <div class="script-log">&#9656; @log</div>
                            }
                            @if (sr.Error is null && sr.Logs.Count == 0 &&
                                 sr.Mutations.Request.Count == 0 &&
                                 sr.Mutations.Collection.Count == 0 &&
                                 sr.Mutations.Global.Count == 0)
                            {
                                <div class="empty-hint">Script exécuté sans sortie ni mutation.</div>
                            }
                        </div>
                    }
                    else
                    {
                        <JsonViewer Value="@FormatBody(tab.Result.Body)" />
                    }
                </div>
            }
        </div>
    </div>

    @if (_showConflictModal)
    {
        <div class="hf-modal-backdrop">
            <div class="hf-modal">
                <p><strong>Cette requête a été modifiée dans une autre fenêtre à @_conflictAt?.ToString("HH:mm:ss")</strong></p>
                <p>Voulez-vous écraser ces modifications ou annuler ?</p>
                <button class="btn-danger" @onclick="OnSaveOverwriteAsync">Écraser les modifications</button>
                <button @onclick="OnCancelSave">Annuler</button>
            </div>
        </div>
    }

    @if (_showUnsavedModal)
    {
        <div class="hf-modal-backdrop">
            <div class="hf-modal">
                <p><strong>Modifications non sauvegardées</strong></p>
                <p>Cet onglet contient des modifications non sauvegardées.</p>
                <button @onclick="SaveAndCloseAsync">Sauvegarder et fermer</button>
                <button class="btn-danger" @onclick="DiscardAndClose">Fermer sans sauvegarder</button>
                <button @onclick="CancelClose">Annuler</button>
            </div>
        </div>
    }
}

@* Rendered at page level so it works from the empty state (no active tab) too. *@
<CurlImportDialog Visible="_showCurlImport"
                  OnImport="ImportCurlAsync"
                  OnCancel="() => { _showCurlImport = false; }" />

@code {
    private TabState? Active => Tabs.ActiveTab;

    // Last-saved request for the active tab — used by SendAsync / ScriptRunner / variable resolution
    private HttpRequestItem? _request;

    private AppEnvironment? _globalBase;
    private AppEnvironment? _globalSubset;
    private CollectionVariableSet? _collectionBase;
    private CollectionVariableSet? _collectionSubset;
    // Default headers inherited from the active request's collection (read-only here;
    // edited in NavMenu). Applied to every send via RequestExecutor.
    private IReadOnlyList<CollectionDefaultHeader> _collectionDefaultHeaders = [];
    private IReadOnlyList<ResolvedVariableEntry> _resolvedVariables = Array.Empty<ResolvedVariableEntry>();
    private readonly string[] _subTabs = ["Params", "Headers", "Body", "Variables", "Scripts", "Options"];

    // Identifies this circuit so the change notifier can skip notifications for our own
    // saves. Not a user identity — only distinguishes "this window" from "another window".
    private readonly string _originId = Guid.NewGuid().ToString();

    // Modal/toast state
    private bool _showUnsavedModal;
    private int? _pendingCloseTabId;
    private bool _showConflictModal;
    private DateTime? _conflictAt;
    private string? _reloadToast;

    // cURL import/export UI state.
    private bool _showCurlImport;
    private string? _curlNotice;

    // Whether any collection exists — drives the empty-state message.
    private bool _hasCollections;

    private Action? _tabsOnChange;
    private Action<int>? _tabRemoved;

    // Reference handed to forge.shortcuts so the global keydown listener can invoke Send/Save.
    private DotNetObjectReference<Home>? _shortcutsRef;

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += OnStateChanged;
        Notifier.RequestSaved += OnRequestSavedByOther;
        _tabsOnChange = () => InvokeAsync(StateHasChanged);
        Tabs.OnChange += _tabsOnChange;
        Tabs.OnCloseRequested += OnTabCloseRequested;
        // A closed tab must not keep a pending auto-save timer alive (no ghost write to a
        // discarded draft). The DI-scoped AutoSaver is disposed with the circuit.
        _tabRemoved = id => AutoSaver.Cancel(id);
        Tabs.OnTabRemoved += _tabRemoved;

        await LoadEnvAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Tabs.InitAsync(JS);
            _shortcutsRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("forge.shortcuts.init", _shortcutsRef);
            await LoadActiveTabContextAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        State.OnChange -= OnStateChanged;
        Notifier.RequestSaved -= OnRequestSavedByOther;
        if (_tabsOnChange is not null) Tabs.OnChange -= _tabsOnChange;
        Tabs.OnCloseRequested -= OnTabCloseRequested;
        if (_tabRemoved is not null) Tabs.OnTabRemoved -= _tabRemoved;
        // Intentionally do NOT dispose AutoSaver here: it is DI-scoped (circuit lifetime),
        // shared with TabManagerService, and disposed by the container at circuit end.
        // Disposing it on component teardown would leave a re-created Home (internal
        // navigation) with a disposed saver whose Schedule is a silent no-op.

        // Detach the global keyboard listener so a re-created Home doesn't stack handlers
        // (mirrors forge.dnd). JS interop may fail if the circuit is already gone — ignore.
        try { await JS.InvokeVoidAsync("forge.shortcuts.dispose"); } catch { /* circuit closed */ }
        _shortcutsRef?.Dispose();
    }

    private async void OnStateChanged()
    {
        try
        {
            await LoadActiveTabContextAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[HttpForge] State change error: {ex.Message}");
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnTabCloseRequested(TabState tab)
    {
        _pendingCloseTabId = tab.RequestId;
        _showUnsavedModal = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadEnvAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var envs = await db.Environments
            .Include(e => e.Variables)
            .ToListAsync();
        _globalBase = envs.FirstOrDefault(e => e.IsBase);
        // Only non-base environments are selectable; base is always loaded as _globalBase
        _globalSubset = State.SelectedEnvironmentId is int id
            ? envs.FirstOrDefault(e => e.Id == id && !e.IsBase)
            : null;
        RebuildVariables();
    }

    // Loads the saved request + collection var sets for the ACTIVE tab.
    // The editable draft itself lives in TabState and is NOT reloaded here.
    private async Task LoadActiveTabContextAsync()
    {
        await LoadEnvAsync();

        var active = Active;
        if (active is null)
        {
            // Empty state: drives the message ("first request" vs "select one") and never
            // touches request/collection context.
            await using (var probe = await DbFactory.CreateDbContextAsync())
                _hasCollections = await probe.Collections.AnyAsync();
            _request = null;
            _collectionBase = null;
            _collectionSubset = null;
            _collectionDefaultHeaders = [];
            State.SelectedCollectionId = null;
            RebuildVariables();
            return;
        }

        // A collection-settings tab has no request to load; it only points the app at its
        // collection so variable resolution elsewhere stays consistent.
        if (active.Kind == TabKind.CollectionSettings)
        {
            _request = null;
            _collectionBase = null;
            _collectionSubset = null;
            _collectionDefaultHeaders = [];
            State.SelectedCollectionId = active.CollectionId;
            RebuildVariables();
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var request = await db.Requests
            .Include(r => r.Headers)
            .Include(r => r.QueryParams)
            .Include(r => r.FormFields)
            .Include(r => r.Variables)
            .FirstOrDefaultAsync(r => r.Id == active.RequestId);

        var collection = request is null ? null : await db.Collections
            .Include(c => c.VariableSets).ThenInclude(s => s.Entries)
            .Include(c => c.DefaultHeaders)
            .FirstOrDefaultAsync(c => c.Id == request.CollectionId);

        // A concurrent activate/close may have changed the active tab while we awaited;
        // a fresh OnStateChanged is already in flight for the new tab, so bail out.
        if (!ReferenceEquals(Active, active)) return;

        _collectionBase = collection?.VariableSets.FirstOrDefault(s => s.IsBase);
        _collectionSubset = collection?.ActiveCollectionVariableSetId is int sid
            ? collection.VariableSets.FirstOrDefault(s => s.Id == sid && !s.IsBase)
            : null;
        _collectionDefaultHeaders = collection?.DefaultHeaders.ToList() ?? [];

        State.SelectedCollectionId = request?.CollectionId;
        _request = request;
        RebuildVariables();
    }

    private void RebuildVariables()
    {
        _resolvedVariables = State.BuildVariables(
            _globalBase, _globalSubset, _collectionBase, _collectionSubset,
            _request);
    }

    private string Tooltip(string? text) => VariablePreview.Build(text, _resolvedVariables);

    private async Task CopyUrlAsync(string url)
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", url); }
        catch { /* clipboard unavailable (non-HTTPS or denied) */ }
    }

    // ── Field mutators — write to the active tab's draft only ──────────────────

    // Marks a tab dirty and (re)arms its debounced auto-save. The captured tab — not
    // Active — is what the scheduled save targets, so a late timer never writes one tab's
    // draft into another (mirrors the OnBodyChanged/OnPostScriptChanged guard).
    private void MarkDirtyAndSchedule(TabState tab)
    {
        tab.Draft.MarkDirty();
        AutoSaver.Schedule(tab.RequestId, _ => InvokeAsync(() => AutoSaveTabAsync(tab)));
    }

    private async Task AutoSaveTabAsync(TabState tab)
    {
        await SaveTabAsync(tab, forceOverwrite: false, isAuto: true);
        StateHasChanged();
    }

    private void OnNameInput(ChangeEventArgs e)
    {
        if (Active is null) return;
        Active.Draft.Name = e.Value?.ToString() ?? string.Empty;
        Active.Name = Active.Draft.Name;
        MarkDirtyAndSchedule(Active);
    }

    private void OnMethodChanged(ChangeEventArgs e)
    {
        if (Active is null) return;
        if (Enum.TryParse<HttpMethodKind>(e.Value?.ToString(), out var m))
        {
            Active.Draft.Method = m;
            Active.Method = m.ToString();
            MarkDirtyAndSchedule(Active);
        }
    }

    private void OnUrlChanged(string value)
    {
        if (Active is null) return;
        Active.Draft.Url = value;
        MarkDirtyAndSchedule(Active);
    }

    private void OnIgnoreTlsChanged(ChangeEventArgs e)
    {
        if (Active is null) return;
        Active.Draft.IgnoreTlsErrors = e.Value is true;
        MarkDirtyAndSchedule(Active);
    }

    // These two are fed by debounced CodeMirror callbacks that can land *after* a tab
    // switch — they take the tab they were rendered for instead of reading Active, so a
    // late callback can never write one tab's content into another tab's draft.
    private void OnBodyChanged(TabState tab, string value)
    {
        tab.Draft.BodyContent = value;
        MarkDirtyAndSchedule(tab);
    }

    private void OnPostScriptChanged(TabState tab, string value)
    {
        tab.Draft.PostScript = value;
        // Editing the script in the editor is an explicit authoring/review action, so the
        // script becomes trusted and may execute on the next send.
        tab.Draft.PostScriptTrusted = true;
        MarkDirtyAndSchedule(tab);
    }

    private async Task EnableScriptAsync()
    {
        if (Active is null) return;
        Active.Draft.PostScriptTrusted = true;
        // Persist immediately (no debounce): mark dirty then save now. SaveDraftAsync
        // reloads _request so the next send sees the script as trusted and runs it, and
        // cancels any pending auto-save timer on success.
        Active.Draft.MarkDirty();
        await SaveDraftAsync(forceOverwrite: false);
    }

    private void OnBodyKindChanged(BodyKind kind)
    {
        if (Active is null) return;
        Active.Draft.BodyKind = kind;
        MarkDirtyAndSchedule(Active);
    }

