@implements IDisposable
@inject TabManagerService Tabs

<div class="tab-bar" @oncontextmenu:preventDefault>
    @foreach (var tab in Tabs.Tabs)
    {
        var isActive = tab.Key == Tabs.ActiveTab?.Key;
        if (tab.Kind == TabKind.CollectionSettings)
        {
            <div class="tab tab-settings @(isActive ? "active" : "")"
                 @onclick="() => Tabs.ActivateTab(tab.Key)">
                <span class="tab-settings-icon">&#9881;</span>
                <span class="tab-name" title="@tab.Name">@tab.Name</span>
                <span class="tab-close"
                      @onclick="() => Tabs.CloseTab(tab.Key)"
                      @onclick:stopPropagation>&#10005;</span>
            </div>
        }
        else
        {
            var isDirty = tab.Draft.IsDirty;
            <div class="tab @(isActive ? "active" : "") @(isDirty ? "dirty" : "")"
                 @onclick="() => Tabs.ActivateTab(tab.Key)"
                 @oncontextmenu="(e) => ShowContextMenu(e, tab.RequestId)">
                <span class="method-badge method-@tab.Method.ToLowerInvariant()">@tab.Method</span>
                @if (isDirty)
                {
                    <span class="tab-dirty">&#10033;</span>
                }
                <span class="tab-name" title="@tab.Name">@tab.Name</span>
                @if (tab.IsLocked)
                {
                    <span class="tab-lock" title="Onglet verrouillé">&#128274;</span>
                }
                else
                {
                    <span class="tab-close"
                          @onclick="() => Tabs.CloseTab(tab.Key)"
                          @onclick:stopPropagation>&#10005;</span>
                }
            </div>
        }
    }
</div>

@if (_contextMenuVisible)
{
    <div class="ctx-overlay" @onclick="HideContextMenu"></div>
    <div class="ctx-menu" style="top:@(_ctxY.ToString("F0"))px;left:@(_ctxX.ToString("F0"))px">
        <div class="ctx-item" @onclick="() => CloseFromCtx(_ctxRequestId)">
            &#10005;&nbsp;&nbsp;Fermer l'onglet
        </div>
        <div class="ctx-item" @onclick="() => ToggleLockFromCtx(_ctxRequestId)">
            &#128274;&nbsp;&nbsp;@(IsCtxLocked() ? "Déverrouiller l'onglet" : "Verrouiller l'onglet")
        </div>
        <div class="ctx-divider"></div>
        <div class="ctx-item" @onclick="() => CloseOthersFromCtx(_ctxRequestId)">
            &#9647;&nbsp;&nbsp;Fermer les autres
        </div>
        @if (HasTabsToRightOf(_ctxRequestId))
        {
            <div class="ctx-item" @onclick="() => CloseRightFromCtx(_ctxRequestId)">
                &#8594;&nbsp;&nbsp;Fermer les onglets à droite
            </div>
        }
        <div class="ctx-item" @onclick="() => CloseCollectionFromCtx(_ctxRequestId)">
            &#9635;&nbsp;&nbsp;Fermer les onglets de la collection
        </div>
        <div class="ctx-divider"></div>
        <div class="ctx-item danger" @onclick="CloseAllFromCtx">
            &#10005;&#10005;&nbsp;Fermer tous les onglets
        </div>
    </div>
}

@code {
    private bool _contextMenuVisible;
    private double _ctxX, _ctxY;
    private int _ctxRequestId;
    private Action? _onChange;

    protected override void OnInitialized()
    {
        _onChange = () => InvokeAsync(StateHasChanged);
        Tabs.OnChange += _onChange;
    }

    public void Dispose()
    {
        if (_onChange is not null) Tabs.OnChange -= _onChange;
    }

    private void ShowContextMenu(MouseEventArgs e, int requestId)
    {
        _ctxX = e.ClientX;
        _ctxY = e.ClientY;
        _ctxRequestId = requestId;
        _contextMenuVisible = true;
    }

    private void HideContextMenu() => _contextMenuVisible = false;

    private void CloseFromCtx(int requestId)       { Tabs.CloseTab(requestId); HideContextMenu(); }
    private void CloseOthersFromCtx(int requestId) { Tabs.CloseOtherTabs(requestId); HideContextMenu(); }
    private void CloseRightFromCtx(int requestId)  { Tabs.CloseTabsToTheRight(requestId); HideContextMenu(); }
    private void CloseCollectionFromCtx(int requestId) { Tabs.CloseTabsOfCollection(requestId); HideContextMenu(); }
    private void CloseAllFromCtx()                 { Tabs.CloseAllTabs(); HideContextMenu(); }
    private void ToggleLockFromCtx(int requestId)  { Tabs.ToggleLock(requestId); HideContextMenu(); }

    private bool IsCtxLocked()
    {
        var key = TabState.RequestKey(_ctxRequestId);
        return Tabs.Tabs.FirstOrDefault(t => t.Key == key)?.IsLocked ?? false;
    }

    private bool HasTabsToRightOf(int requestId)
    {
        var tabs = Tabs.Tabs;
        for (var i = 0; i < tabs.Count - 1; i++)
            if (tabs[i].RequestId == requestId) return true;
        return false;
    }
}
