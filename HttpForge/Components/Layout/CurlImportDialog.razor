@* Modal to paste a cURL command. Presentational only: the parent owns parsing and applies
   the result. Closes on outside click and Escape (mirrors OpenApiUrlDialog). *@

@if (Visible)
{
    <div class="curl-dialog-overlay" @onclick="Cancel">
        <div class="curl-dialog" @onclick:stopPropagation>
            <div class="curl-dialog-title">Coller une commande cURL</div>
            <textarea class="curl-dialog-input"
                      rows="8"
                      placeholder="curl 'https://api.example.com/users' -H 'Accept: application/json'"
                      @bind="_text" @bind:event="oninput"
                      @onkeydown="OnKey"
                      @ref="_inputRef"></textarea>
            <div class="curl-dialog-hint">La requête active sera remplacée par le contenu de la commande.</div>
            <div class="curl-dialog-actions">
                <button class="curl-dialog-cancel" @onclick="Cancel">Annuler</button>
                <button class="curl-dialog-primary"
                        @onclick="Submit"
                        disabled="@string.IsNullOrWhiteSpace(_text)">Importer</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<string> OnImport { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private string _text = string.Empty;
    private bool _wasVisible;
    private bool _focusQueued;
    private ElementReference _inputRef;

    protected override void OnParametersSet()
    {
        // Reset the textarea and queue focus each time the dialog opens.
        if (Visible && !_wasVisible)
        {
            _text = string.Empty;
            _focusQueued = true;
        }
        _wasVisible = Visible;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusQueued && Visible)
        {
            _focusQueued = false;
            try { await _inputRef.FocusAsync(); } catch { /* element gone: ignore */ }
        }
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_text)) return;
        await OnImport.InvokeAsync(_text);
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();

    private async Task OnKey(KeyboardEventArgs e)
    {
        // Ctrl/Cmd+Enter submits (Enter alone inserts a newline in the textarea).
        if (e.Key == "Enter" && (e.CtrlKey || e.MetaKey)) await Submit();
        else if (e.Key == "Escape") await Cancel();
    }
}
