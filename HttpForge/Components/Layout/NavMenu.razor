    private async Task DeleteSubset(AppEnvironment s)
    {
        var msg = s.Variables.Count > 0
            ? $"Supprimer le sous-ensemble « {s.Name} » et ses {s.Variables.Count} variable(s) ?"
            : $"Supprimer le sous-ensemble « {s.Name} » ?";
        if (!await _confirm.AskAsync(msg)) return;
        using var db = await DbFactory.CreateDbContextAsync();
        db.Environments.Remove(await db.Environments.FirstAsync(e => e.Id == s.Id));
        var wasActive = State.SelectedEnvironmentId == s.Id;
        if (wasActive)
        {
            var settings = await db.Settings.FirstAsync(x => x.Id == 1);
            settings.ActiveGlobalSubsetId = null;
        }
        await db.SaveChangesAsync();
        if (wasActive) State.SelectedEnvironmentId = null;
        State.NotifyChanged();
        await ReloadAsync();
    }

