@rendermode InteractiveServer
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AppState State
@inject IJSRuntime JS
@inject InsomniaImporter Importer
@inject OpenApiImporter OpenApiImporter
@inject IHttpClientFactory HttpClientFactory
@inject TabManagerService Tabs
@implements IDisposable

<div class="brand">
    <span class="brand-mark">⚡</span>
    <span class="brand-name">HttpForge</span>
</div>

<div class="env-block">
    <label>Global variables</label>
    <div class="env-row">
        <select value="@(State.SelectedEnvironmentId?.ToString() ?? "")" @onchange="OnSubsetChanged">
            <option value="">— base only —</option>
            @foreach (var s in _globalSubsets)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
        <button class="icon-btn" title="Manage global variables" @onclick="ToggleEnvEditor">@(_showEnvEditor ? "✕" : "⚙")</button>
    </div>
    @if (_showEnvEditor)
    {
        <div class="env-editor">
            <div class="env-editor-header" title="Fermer le panneau" @onclick="ToggleEnvEditor">
                <span>Variables globales</span>
                <span class="close-x">✕</span>
            </div>
            @if (_globalBase is not null)
            {
                <div class="var-list">
                    <div class="var-list-header"><span>Base</span></div>
                    @foreach (var v in _globalBase.Variables)
                    {
                        var masked = v.IsSecret && !_revealed.Contains(v.Id);
                        <div class="var-row">
                            <input placeholder="key" value="@v.Key" @oninput="e => OnVarKeyChanged(v, e)" />
                            <input placeholder="value" type="@(masked ? "password" : "text")"
                                   value="@v.Value" @oninput="e => OnVarValueChanged(v, e)" />
                            @if (v.IsSecret)
                            {
                                <button class="icon-btn" title="@(masked ? "Reveal" : "Hide")"
                                        @onclick="() => ToggleReveal(v)">@(masked ? "👁" : "🚫")</button>
                            }
                            <button class="icon-btn @(v.IsSecret ? "active" : "")"
                                    title="@(v.IsSecret ? "Unmark as secret" : "Mark as secret")"
                                    @onclick="() => ToggleSecret(v)">@(v.IsSecret ? "🔒" : "🔓")</button>
                            <button class="icon-btn" @onclick="() => RemoveVar(v)">✕</button>
                        </div>
                    }
                    <button class="link-btn" @onclick="AddBaseVar">+ add base variable</button>
                </div>
            }
            <div class="var-list" style="margin-top:0.5rem">
                <div class="var-list-header"><span>Sub-sets</span></div>
                <div class="env-actions">
                    <input placeholder="New sub-set name" @bind="_newEnvName" @bind:event="oninput" />
                    <button @onclick="AddSubset" disabled="@string.IsNullOrWhiteSpace(_newEnvName)">Add</button>
                </div>
                @foreach (var s in _globalSubsets)
                {
                    <div class="var-list" style="margin-top:0.3rem">
                        <div class="var-list-header">
                            <span>@s.Name</span>
                            <button class="link-btn" @onclick="() => DeleteSubset(s)">delete</button>
                        </div>
                        @foreach (var v in s.Variables)
                        {
                            var masked = v.IsSecret && !_revealed.Contains(v.Id);
                            <div class="var-row">
                                <input placeholder="key" value="@v.Key" @oninput="e => OnVarKeyChanged(v, e)" />
                                <input placeholder="value" type="@(masked ? "password" : "text")"
                                       value="@v.Value" @oninput="e => OnVarValueChanged(v, e)" />
                                @if (v.IsSecret)
                                {
                                    <button class="icon-btn" title="@(masked ? "Reveal" : "Hide")"
                                            @onclick="() => ToggleReveal(v)">@(masked ? "👁" : "🚫")</button>
                                }
                                <button class="icon-btn @(v.IsSecret ? "active" : "")"
                                        title="@(v.IsSecret ? "Unmark as secret" : "Mark as secret")"
                                        @onclick="() => ToggleSecret(v)">@(v.IsSecret ? "🔒" : "🔓")</button>
                                <button class="icon-btn" @onclick="() => RemoveVar(v)">✕</button>
                            </div>
                        }
                        <button class="link-btn" @onclick="() => AddSubsetVar(s)">+ add variable</button>
                    </div>
                }
            </div>
        </div>
    }
</div>

<div class="section-title">
    <span>Collections</span>
    <div class="import-wrap">
        <button class="icon-btn @(_showImportMenu ? "active" : "")" title="Import"
                @onclick="() => _showImportMenu = !_showImportMenu">↓ Import ▾</button>
        @if (_showImportMenu)
        {
            <div class="menu-backdrop" @onclick="() => _showImportMenu = false"></div>
            <div class="context-menu">
                <label class="context-menu-item">
                    <span>📥</span> Insomnia (YAML)
                    <InputFile accept=".yaml,.yml" multiple OnChange="OnImportFiles" style="display:none" />
                </label>
                <label class="context-menu-item">
                    <span>📥</span> OpenAPI / Swagger — fichier
                    <InputFile accept=".json,.yaml,.yml" multiple OnChange="OnImportOpenApiFiles" style="display:none" />
                </label>
                <button class="context-menu-item"
                        @onclick="() => { _showOpenApiUrl = true; _urlError = null; _showImportMenu = false; }">
                    <span>🔗</span> OpenAPI / Swagger — URL
                </button>
            </div>
        }
    </div>
</div>

@if (_importStatus is not null)
{
    <div class="import-status">@_importStatus</div>
}

@if (_showAddCollection)
{
    <div class="inline-add">
        <input placeholder="Collection name" @bind="_newCollectionName" @bind:event="oninput" @onkeyup="OnNewCollectionKey" />
        <button @onclick="AddCollection" disabled="@string.IsNullOrWhiteSpace(_newCollectionName)">Add</button>
        <button class="link-btn" @onclick="() => _showAddCollection = false">cancel</button>
    </div>
}

<div class="filter-box">
    <input placeholder="Filter..."
           value="@_filterText"
           @oninput="e => _filterText = e.Value?.ToString() ?? string.Empty" />
    @if (!string.IsNullOrEmpty(_filterText))
    {
        <button class="icon-btn" title="Clear filter" @onclick="() => _filterText = string.Empty">✕</button>
    }
    <button class="icon-btn" title="New collection" @onclick="StartAddCollection">+</button>
</div>

<OpenApiUrlDialog Visible="_showOpenApiUrl"
                  Busy="_urlImporting"
                  Error="@_urlError"
                  OnImport="ImportOpenApiUrl"
                  OnCancel="CancelUrlDialog" />

<OpenApiUrlDialog Visible="_showRefreshDialog"
                  Busy="_refreshBusy"
                  Error="@_refreshError"
                  InitialUrl="@_refreshInitialUrl"
                  Title="Actualiser depuis OpenAPI"
                  PrimaryLabel="Actualiser"
                  BusyLabel="Actualisation…"
                  OnImport="RefreshCollectionFromUrl"
                  OnCancel="CancelRefreshDialog" />

<div class="collection-tree">
    @foreach (var c in _collections.Where(c => CollectionHasMatch(c)))
    {
        <div class="collection-node">
            <div class="collection-header"
                 @onmouseenter="() => _hoveredCollectionId = c.Id"
                 @onmouseleave="() => { _hoveredCollectionId = null; _openCollectionMenuId = null; }">
                @if (_renamingCollectionId == c.Id)
                {
                    <span class="caret">@(_expanded.Contains(c.Id) ? "▾" : "▸")</span>
                    <input class="collection-rename-input"
                           @ref="_collectionRenameInput"
                           value="@_renameCollectionValue"
                           @oninput="e => _renameCollectionValue = e.Value?.ToString() ?? string.Empty"
                           @onblur="() => CommitRenameCollection(c)"
                           @onkeydown="e => OnCollectionRenameKeyDown(c, e)"
                           @onclick:stopPropagation />
                }
                else
                {
                <button class="collection-toggle" @onclick="() => ToggleCollection(c.Id)">
                    <span class="caret">@(_expanded.Contains(c.Id) ? "▾" : "▸")</span>
                    <span class="collection-icon">📦</span>
                    <span class="collection-name">@c.Name</span>
                </button>
                var quickSubsets = c.VariableSets.Where(s => !s.IsBase).ToList();
                if (quickSubsets.Count > 0)
                {
                    <select class="subset-quick-select"
                            title="Set de variables actif"
                            value="@(c.ActiveCollectionVariableSetId?.ToString() ?? "")"
                            @onchange="e => OnCollSubsetChanged(c, e)"
                            @onclick:stopPropagation>
                        <option value="">Base</option>
                        @foreach (var s in quickSubsets)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                }
                <button class="icon-btn coll-vars-btn"
                        title="Paramètres de collection"
                        @onclick:stopPropagation
                        @onclick="() => Tabs.OpenCollectionSettingsTabAsync(c.Id)">
                    <span class="coll-vars-glyph">&#123;&#125;</span>
                </button>
                <div class="gear-wrap @(_hoveredCollectionId == c.Id ? "visible" : "")">
                    <button class="icon-btn gear-btn"
                            title="Actions"
                            @onclick:stopPropagation
                            @onclick="() => _openCollectionMenuId = (_openCollectionMenuId == c.Id ? (int?)null : c.Id)">
                        ⚙
                    </button>
                    @if (_openCollectionMenuId == c.Id)
                    {
                        <div class="context-menu">
                            <button class="context-menu-item"
                                    @onclick:stopPropagation
                                    @onclick="() => { _ = Tabs.OpenCollectionSettingsTabAsync(c.Id); _openCollectionMenuId = null; }">
                                <span class="coll-vars-glyph">&#123;&#125;</span> Paramètres de collection
                            </button>
                            <button class="context-menu-item"
                                    @onclick:stopPropagation
                                    @onclick="() => { StartAddFolder(c.Id); _openCollectionMenuId = null; }">
                                <span>📁</span> Nouveau dossier
                            </button>
                            <button class="context-menu-item"
                                    @onclick:stopPropagation
                                    @onclick="() => { _ = AddRequest(c); _openCollectionMenuId = null; }">
                                <span>＋</span> Nouvelle requête
                            </button>
                            <button class="context-menu-item"
                                    @onclick:stopPropagation
                                    @onclick="() => { StartRenameCollection(c); _openCollectionMenuId = null; }">
                                <span>✏</span> Renommer
                            </button>
                            <button class="context-menu-item"
                                    @onclick:stopPropagation
                                    @onclick="() => { StartRefreshFromOpenApi(c); _openCollectionMenuId = null; }">
                                <span>🔄</span> Actualiser depuis OpenAPI…
                            </button>
                            <button class="context-menu-item danger"
                                    @onclick:stopPropagation
                                    @onclick="() => { _ = DeleteCollection(c); _openCollectionMenuId = null; }">
                                <span>🗑</span> Supprimer la collection
                            </button>
                        </div>
                    }
                </div>
                }
            </div>
            @if (_showAddFolder && _addingFolderCollectionId == c.Id)
            {
                <div class="inline-add">
                    <input placeholder="Folder name" @bind="_newFolderName" @bind:event="oninput"
                           @onkeydown="OnNewFolderKey" />
                    <button @onclick="CommitAddFolder" disabled="@string.IsNullOrWhiteSpace(_newFolderName)">Add</button>
                    <button class="link-btn" @onclick="() => _showAddFolder = false">cancel</button>
                </div>
            }
            @if (_expanded.Contains(c.Id) || !string.IsNullOrWhiteSpace(_filterText))
            {
                <div class="request-list" data-drop="collection:@c.Id">
                    <CollectionNode CollectionId="c.Id"
                                    ParentFolderId="@((int?)null)"
                                    AllFolders="_allFolders.Where(f => f.CollectionId == c.Id).ToList()"
                                    AllRequests="c.Requests"
                                    OnChanged="ReloadAndNotify"
                                    FilterText="@(string.IsNullOrWhiteSpace(_filterText) || c.Name.Contains(_filterText, StringComparison.OrdinalIgnoreCase) ? string.Empty : _filterText)" />
                    @if (!c.Requests.Any(r => r.FolderId == null) &&
                         !_allFolders.Any(f => f.CollectionId == c.Id))
                    {
                        <div class="empty-hint">No requests — click + to add.</div>
                    }
                </div>
            }
        </div>
    }
    @if (_collections.Count == 0)
    {
        <div class="empty-hint">No collections yet.</div>
    }
</div>

<ConfirmDialog Visible="_confirm.Visible"
               Title="@_confirm.Title"
               Message="@_confirm.Message"
               ConfirmLabel="@_confirm.ConfirmLabel"
               Danger="_confirm.Danger"
               OnConfirm="_confirm.Confirm"
               OnCancel="_confirm.Cancel" />

@code {
    private List<Collection> _collections = new();
    private List<CollectionFolder> _allFolders = [];
    private AppEnvironment? _globalBase;
    private List<AppEnvironment> _globalSubsets = new();
    private HashSet<int> _expanded = new();
    private string _filterText = string.Empty;
    private bool _showAddCollection;
    private string _newCollectionName = string.Empty;
    private bool _showImportMenu;
    private bool _showOpenApiUrl;
    private bool _urlImporting;
    private string? _urlError;
    private bool _showRefreshDialog;
    private bool _refreshBusy;
    private string? _refreshError;
    private string _refreshInitialUrl = string.Empty;
    private int? _refreshingCollectionId;
    private bool _showEnvEditor;
    private string _newEnvName = string.Empty;
    private HashSet<int> _revealed = new();
    private string? _importStatus;
    private bool _disposed;
    private int? _hoveredCollectionId;
    private int? _openCollectionMenuId;
    private int? _renamingCollectionId;
    private string _renameCollectionValue = string.Empty;
    private bool _shouldFocusCollectionRename;
    private ElementReference _collectionRenameInput;
    private DotNetObjectReference<NavMenu>? _dndRef;
    private readonly ConfirmState _confirm = new();

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += OnStateChanged;
        State.OpenImportRequested += OnOpenImportRequested;
        State.OpenEnvEditorRequested += OnOpenEnvEditorRequested;
        _confirm.OnChange = () => InvokeAsync(StateHasChanged);
        await LoadSettingsAsync();
        await ReloadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dndRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("forge.dnd.init", _dndRef);
        }

        if (_shouldFocusCollectionRename && _renamingCollectionId.HasValue)
        {
            _shouldFocusCollectionRename = false;
            try { await _collectionRenameInput.FocusAsync(); } catch { }
        }
    }

    private async Task LoadSettingsAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var settings = await db.Settings.FirstOrDefaultAsync(s => s.Id == 1);
        State.SelectedEnvironmentId = settings?.ActiveGlobalSubsetId;
        State.NotifyChanged();
    }

    public void Dispose()
    {
        _disposed = true;
        State.OnChange -= OnStateChanged;
        State.OpenImportRequested -= OnOpenImportRequested;
        State.OpenEnvEditorRequested -= OnOpenEnvEditorRequested;
        _dndRef?.Dispose();
    }

    // Opens the import menu when another component (Home empty state) requests it.
    private void OnOpenImportRequested()
    {
        _showImportMenu = true;
        InvokeAsync(StateHasChanged);
    }

    // Opens the global variables editor when the workspace env badge is clicked.
    private void OnOpenEnvEditorRequested()
    {
        _showEnvEditor = true;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnDrop(string drag, string drop)
    {
        if (!TryParseDnd(drag, out var dragType, out var dragId)) return;
        if (!TryParseDnd(drop, out var dropType, out var dropId)) return;

        int targetCollectionId;
        int? targetFolderId;

        if (dropType == "collection")
        {
            if (!_collections.Any(c => c.Id == dropId)) return;
            targetCollectionId = dropId;
            targetFolderId = null;
        }
        else // "folder"
        {
            var targetFolder = _allFolders.FirstOrDefault(f => f.Id == dropId);
            if (targetFolder == null) return;
            targetCollectionId = targetFolder.CollectionId;
            targetFolderId = dropId;
        }

        if (dragType == "request")
        {
            var draggedReq = _collections.SelectMany(c => c.Requests).FirstOrDefault(r => r.Id == dragId);
            if (draggedReq != null && draggedReq.CollectionId == targetCollectionId && draggedReq.FolderId == targetFolderId) return;
            await MoveRequestAsync(dragId, targetCollectionId, targetFolderId);
        }
        else // "folder"
        {
            if (dropType == "folder" && IsDescendantOrSelf(dragId, dropId)) return;
            var dragged = _allFolders.FirstOrDefault(f => f.Id == dragId);
            if (dragged == null) return;
            if (dragged.ParentFolderId == targetFolderId && dragged.CollectionId == targetCollectionId) return;
            await MoveFolderAsync(dragId, targetCollectionId, targetFolderId);
        }

        await ReloadAsync();
        State.NotifyChanged();
        await InvokeAsync(StateHasChanged);
    }

    private static bool TryParseDnd(string value, out string type, out int id)
    {
        type = string.Empty; id = 0;
        var idx = value.IndexOf(':');
        if (idx < 1) return false;
        type = value[..idx];
        return int.TryParse(value[(idx + 1)..], out id);
    }

    private bool IsDescendantOrSelf(int folderId, int candidateId)
    {
        if (folderId == candidateId) return true;
        var children = _allFolders.Where(f => f.ParentFolderId == folderId);
        return children.Any(c => IsDescendantOrSelf(c.Id, candidateId));
    }

    private async Task MoveRequestAsync(int requestId, int targetCollectionId, int? targetFolderId)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var req = await db.Requests.FirstOrDefaultAsync(r => r.Id == requestId);
        if (req == null) return;
        req.CollectionId = targetCollectionId;
        req.FolderId = targetFolderId;
        req.UpdatedAt = DateTime.UtcNow;
        await db.SaveChangesAsync();
    }

    private async Task MoveFolderAsync(int folderId, int targetCollectionId, int? targetParentFolderId)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var folder = await db.CollectionFolders.FirstOrDefaultAsync(f => f.Id == folderId);
        if (folder == null) return;

        var oldCollectionId = folder.CollectionId;
        folder.CollectionId = targetCollectionId;
        folder.ParentFolderId = targetParentFolderId;

        if (oldCollectionId != targetCollectionId)
            await UpdateDescendantsCollectionAsync(db, folderId, targetCollectionId);

        await db.SaveChangesAsync();
    }

    // Mutates tracked entities without calling SaveChangesAsync.
    // Caller (MoveFolderAsync) flushes all changes in a single SaveChangesAsync via EF change tracker.
    private async Task UpdateDescendantsCollectionAsync(AppDbContext db, int folderId, int targetCollectionId)
    {
        var childFolders = await db.CollectionFolders
            .Where(f => f.ParentFolderId == folderId)
            .ToListAsync();
        foreach (var child in childFolders)
        {
            child.CollectionId = targetCollectionId;
            await UpdateDescendantsCollectionAsync(db, child.Id, targetCollectionId);
        }
        var childRequests = await db.Requests
            .Where(r => r.FolderId == folderId)
            .ToListAsync();
        foreach (var r in childRequests)
            r.CollectionId = targetCollectionId;
    }

    private async void OnStateChanged()
    {
        try
        {
            await ReloadAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[HttpForge] NavMenu reload error: {ex.Message}");
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReloadAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();

        _collections = await db.Collections
            .Include(c => c.Requests)
            .Include(c => c.VariableSets).ThenInclude(s => s.Entries)
            .Include(c => c.DefaultHeaders)
            .OrderBy(c => c.Name)
            .ToListAsync();

        _allFolders = await db.CollectionFolders.ToListAsync();
        var envs = await db.Environments
            .Include(e => e.Variables)
            .OrderBy(e => e.Name)
            .ToListAsync();
        _globalBase = envs.FirstOrDefault(e => e.IsBase);
        _globalSubsets = envs.Where(e => !e.IsBase).ToList();
    }

    private void ToggleCollection(int id)
    {
        if (!_expanded.Add(id)) _expanded.Remove(id);
    }

    private void StartAddCollection()
    {
        _showAddCollection = true;
        _newCollectionName = string.Empty;
    }

    private int? _addingFolderCollectionId;
    private string _newFolderName = string.Empty;
    private bool _showAddFolder;

    private void StartAddFolder(int collectionId)
    {
        _addingFolderCollectionId = collectionId;
        _newFolderName = string.Empty;
        _showAddFolder = true;
        _expanded.Add(collectionId);
    }

    private async Task CommitAddFolder()
    {
        if (string.IsNullOrWhiteSpace(_newFolderName) || _addingFolderCollectionId is null)
        {
            _showAddFolder = false;
            return;
        }
        using var db = await DbFactory.CreateDbContextAsync();
        db.CollectionFolders.Add(new CollectionFolder
        {
            CollectionId = _addingFolderCollectionId.Value,
            ParentFolderId = null,
            Name = _newFolderName.Trim()
        });
        await db.SaveChangesAsync();
        _showAddFolder = false;
        _addingFolderCollectionId = null;
        _newFolderName = string.Empty;
        await ReloadAsync();
        State.NotifyChanged();
    }

    private async Task OnNewFolderKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CommitAddFolder();
        else if (e.Key == "Escape") _showAddFolder = false;
    }

    private async Task OnImportFiles(InputFileChangeEventArgs e)
    {
        _showImportMenu = false;
        _importStatus = null;
        int totalCollections = 0;
        int totalRequests = 0;
        int totalFolders = 0;
        var errors = new List<string>();
        var warnings = new List<string>();

        foreach (var file in e.GetMultipleFiles(maximumFileCount: 20))
        {
            try
            {
                using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                var result = await Importer.ImportFileAsync(stream, file.Name);
                if (result.RequestsCreated > 0 || result.FoldersCreated > 0)
                {
                    totalCollections++;
                    totalRequests += result.RequestsCreated;
                    totalFolders += result.FoldersCreated;
                }
                foreach (var w in result.Warnings)
                    warnings.Add($"{file.Name}: {w}");
            }
            catch (Exception ex)
            {
                errors.Add($"{file.Name}: {ex.Message}");
            }
        }

        if (errors.Count > 0)
            _importStatus = $"Import error: {string.Join("; ", errors)}";
        else
        {
            _importStatus = $"Imported: {totalCollections} collection(s), {totalFolders} folder(s), {totalRequests} request(s)";
            if (warnings.Count > 0)
                _importStatus += $" — ⚠ {string.Join("; ", warnings)}";
        }

        await ReloadAsync();
        State.NotifyChanged();
        await InvokeAsync(StateHasChanged);

        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            if (!_disposed)
                InvokeAsync(() => { _importStatus = null; StateHasChanged(); });
        }, TaskScheduler.Default);
    }

    private async Task OnImportOpenApiFiles(InputFileChangeEventArgs e)
    {
        _showImportMenu = false;
        _importStatus = null;
        int collections = 0, requests = 0, folders = 0;
        var errors = new List<string>();
        var warnings = new List<string>();

        foreach (var file in e.GetMultipleFiles(maximumFileCount: 20))
        {
            try
            {
                using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                var result = await OpenApiImporter.ImportFileAsync(stream, file.Name);
                if (result.RequestsCreated > 0 || result.FoldersCreated > 0) collections++;
                requests += result.RequestsCreated;
                folders += result.FoldersCreated;
                foreach (var w in result.Warnings) warnings.Add($"{file.Name}: {w}");
            }
            catch (Exception ex)
            {
                errors.Add($"{file.Name}: {ex.Message}");
            }
        }

        await ReportImportAsync(collections, folders, requests, errors, warnings);
    }

    private async Task ImportOpenApiUrl(string url)
    {
        if (string.IsNullOrWhiteSpace(url)) return;

        _urlError = null;
        _urlImporting = true;

        // http(s) only; on failure the dialog stays open and shows a readable error
        // (never an unhandled exception). The download is size- and time-bounded.
        if (!Uri.TryCreate(url, UriKind.Absolute, out var uri) ||
            (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps))
        {
            _urlError = "URL invalide (http/https attendu).";
            _urlImporting = false;
            return;
        }

        int collections = 0, requests = 0, folders = 0;
        var warnings = new List<string>();
        try
        {
            using var buffer = await FetchSpecAsync(uri);
            var name = uri.Segments.LastOrDefault() is { Length: > 1 } segment ? segment : uri.Host;
            // Store the source URL so the collection can be refreshed from the same spec later.
            var result = await OpenApiImporter.ImportFileAsync(buffer, name, url.Trim());
            if (result.RequestsCreated > 0 || result.FoldersCreated > 0) collections++;
            requests += result.RequestsCreated;
            folders += result.FoldersCreated;
            foreach (var w in result.Warnings) warnings.Add($"{name}: {w}");
        }
        catch (Exception ex)
        {
            _urlError = $"Échec de l'import : {ex.Message}";
            _urlImporting = false;
            return;
        }

        _urlImporting = false;
        _showOpenApiUrl = false;
        await ReportImportAsync(collections, folders, requests, [], warnings);
    }

    private void CancelUrlDialog()
    {
        _showOpenApiUrl = false;
        _urlError = null;
    }

    private void StartRefreshFromOpenApi(Collection c)
    {
        _refreshingCollectionId = c.Id;
        _refreshInitialUrl = c.SourceOpenApiUrl ?? string.Empty;
        _refreshError = null;
        _showRefreshDialog = true;
    }

    private async Task RefreshCollectionFromUrl(string url)
    {
        if (string.IsNullOrWhiteSpace(url) || _refreshingCollectionId is not { } collectionId) return;

        _refreshError = null;
        _refreshBusy = true;

        // http(s) only; on failure the dialog stays open with a readable error.
        if (!Uri.TryCreate(url, UriKind.Absolute, out var uri) ||
            (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps))
        {
            _refreshError = "URL invalide (http/https attendu).";
            _refreshBusy = false;
            return;
        }

        // Persist the (possibly edited) URL first, so a failed refresh still keeps the correction.
        await SaveSourceUrlAsync(collectionId, url.Trim());

        RefreshResult result;
        try
        {
            using var buffer = await FetchSpecAsync(uri);
            result = await OpenApiImporter.RefreshCollectionAsync(buffer, collectionId);
        }
        catch (Exception ex)
        {
            _refreshError = $"Échec de l'actualisation : {ex.Message}";
            _refreshBusy = false;
            return;
        }

        _refreshBusy = false;
        _showRefreshDialog = false;
        _refreshingCollectionId = null;
        await ReportRefreshAsync(result);
    }

    private void CancelRefreshDialog()
    {
        _showRefreshDialog = false;
        _refreshError = null;
        _refreshingCollectionId = null;
    }

    private async Task SaveSourceUrlAsync(int collectionId, string url)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var collection = await db.Collections.FindAsync(collectionId);
        if (collection is null) return;
        collection.SourceOpenApiUrl = url;
        await db.SaveChangesAsync();
    }

    // Downloads a spec into a rewindable buffer. Size- and time-bounded; shared by import and refresh.
    private async Task<MemoryStream> FetchSpecAsync(Uri uri)
    {
        var client = HttpClientFactory.CreateClient();
        client.Timeout = TimeSpan.FromSeconds(30);
        using var response = await client.GetAsync(uri, HttpCompletionOption.ResponseHeadersRead);
        response.EnsureSuccessStatusCode();

        await using var network = await response.Content.ReadAsStreamAsync();
        var buffer = new MemoryStream();
        await CopyBoundedAsync(network, buffer, 10 * 1024 * 1024);
        buffer.Position = 0;
        return buffer;
    }

    // Transient status line summarizing an OpenAPI refresh (added / removed / completed).
    private async Task ReportRefreshAsync(RefreshResult result)
    {
        var noChange = result.Added == 0 && result.Removed == 0 && result.Completed == 0;
        if (noChange && result.Warnings.Count > 0)
            _importStatus = $"Actualisation : ⚠ {string.Join("; ", result.Warnings)}";
        else
        {
            _importStatus = $"Actualisé : {result.Added} ajouté(s), {result.Removed} supprimé(s), {result.Completed} complété(s)";
            if (result.Warnings.Count > 0)
                _importStatus += $" — ⚠ {string.Join("; ", result.Warnings)}";
        }

        await ReloadAsync();
        State.NotifyChanged();
        await InvokeAsync(StateHasChanged);

        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            if (!_disposed)
                InvokeAsync(() => { _importStatus = null; StateHasChanged(); });
        }, TaskScheduler.Default);
    }

    // Shared status + reload tail for the OpenAPI imports (file and URL).
    private async Task ReportImportAsync(int collections, int folders, int requests, List<string> errors, List<string> warnings)
    {
        if (errors.Count > 0)
            _importStatus = $"Import error: {string.Join("; ", errors)}";
        else
        {
            _importStatus = $"Imported: {collections} collection(s), {folders} folder(s), {requests} request(s)";
            if (warnings.Count > 0)
                _importStatus += $" — ⚠ {string.Join("; ", warnings)}";
        }

        await ReloadAsync();
        State.NotifyChanged();
        await InvokeAsync(StateHasChanged);

        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            if (!_disposed)
                InvokeAsync(() => { _importStatus = null; StateHasChanged(); });
        }, TaskScheduler.Default);
    }

    // Copies at most maxBytes; throws past the cap so an oversized download cannot exhaust memory.
    private static async Task CopyBoundedAsync(Stream source, Stream destination, long maxBytes)
    {
        var buffer = new byte[81920];
        long total = 0;
        int read;
        while ((read = await source.ReadAsync(buffer)) > 0)
        {
            total += read;
            if (total > maxBytes)
                throw new InvalidOperationException($"Réponse trop volumineuse (> {maxBytes / (1024 * 1024)} Mo).");
            await destination.WriteAsync(buffer.AsMemory(0, read));
        }
    }

    private async Task OnNewCollectionKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddCollection();
        else if (e.Key == "Escape") _showAddCollection = false;
    }

    private async Task AddCollection()
    {
        if (string.IsNullOrWhiteSpace(_newCollectionName)) return;
        using var db = await DbFactory.CreateDbContextAsync();

        var c = new Collection { Name = _newCollectionName.Trim() };
        db.Collections.Add(c);
        await db.SaveChangesAsync();
        _expanded.Add(c.Id);
        _newCollectionName = string.Empty;
        _showAddCollection = false;
        await ReloadAsync();
    }

    private void StartRenameCollection(Collection c)
    {
        _renamingCollectionId = c.Id;
        _renameCollectionValue = c.Name;
        _shouldFocusCollectionRename = true;
    }

    private void CancelRenameCollection()
    {
        _renamingCollectionId = null;
        _renameCollectionValue = string.Empty;
    }

    private async Task OnCollectionRenameKeyDown(Collection c, KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CommitRenameCollection(c);
        else if (e.Key == "Escape") CancelRenameCollection();
    }

    private async Task CommitRenameCollection(Collection c)
    {
        if (_renamingCollectionId != c.Id) return;
        var name = _renameCollectionValue.Trim();
        _renamingCollectionId = null;
        if (string.IsNullOrWhiteSpace(name) || name == c.Name) return;

        using var db = await DbFactory.CreateDbContextAsync();
        var col = await db.Collections.FirstAsync(x => x.Id == c.Id);
        col.Name = name;
        await db.SaveChangesAsync();
        await ReloadAsync();
        State.NotifyChanged();
    }

    private async Task DeleteCollection(Collection c)
    {
        var msg = c.Requests.Count > 0
            ? $"Supprimer la collection « {c.Name} » et ses {c.Requests.Count} requête(s) ?"
            : $"Supprimer la collection « {c.Name} » ?";
        if (!await _confirm.AskAsync(msg)) return;
        using var db = await DbFactory.CreateDbContextAsync();
        db.Collections.Remove(await db.Collections.FirstAsync(x => x.Id == c.Id));
        await db.SaveChangesAsync();
        foreach (var r in c.Requests)
            Tabs.ForceCloseTab(r.Id);
        Tabs.CloseCollectionSettingsTab(c.Id);
        await ReloadAsync();
    }

    private async Task AddRequest(Collection c)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var r = new HttpRequestItem
        {
            CollectionId = c.Id,
            Name = "New request",
            Method = HttpMethodKind.GET,
            Url = "https://"
        };
        db.Requests.Add(r);
        await db.SaveChangesAsync();
        _expanded.Add(c.Id);
        await ReloadAsync();
        await Tabs.OpenTabAsync(r.Id);
    }

